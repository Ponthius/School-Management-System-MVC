@model School_Management_System.Models.ViewModels.ClassSubjectsDashboardViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Classes & Subjects";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string CardAccent(string accent)
    {
        return accent switch
        {
            "accent-green" => "card-green",
            "accent-amber" => "card-amber",
            "accent-rose" => "card-rose",
            _ => "card-indigo"
        };
    }

    string InitialCode(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "CL";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        }

        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }
}

@section Styles {
    <style>
        .cs-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 14px;
            margin-bottom: 20px;
        }

        .cs-title {
            margin: 0;
            font-size: 20px;
            line-height: 1.2;
            color: #000666;
            font-weight: 800;
            letter-spacing: -.02em;
        }

        .cs-subtitle {
            margin: 6px 0 0;
            color: #767683;
            font-size: 12px;
        }

        .cs-header-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .cs-btn {
            border: 0;
            border-radius: 6px;
            padding: 9px 12px;
            font-family: inherit;
            font-size: 12px;
            font-weight: 800;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            transition: .16s ease;
        }

        .cs-btn-primary {
            background: #000666;
            color: white;
        }

        .cs-btn-primary:hover {
            opacity: .9;
        }

        .cs-btn-secondary {
            background: white;
            color: #000666;
            border: 1px solid #dfe2ec;
        }

        .cs-btn-secondary:hover {
            background: #f7f8fc;
        }

        .cs-btn-green {
            background: #1b6d24;
            color: white;
        }

        .cs-btn-danger {
            background: #ba1a1a;
            color: white;
        }

        .cs-alert {
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 14px;
            font-weight: 700;
            font-size: 12px;
        }

        .cs-alert-success {
            background: #e8f8ea;
            color: #155d1e;
            border: 1px solid #bdecc2;
        }

        .cs-alert-error {
            background: #ffefed;
            color: #ba1a1a;
            border: 1px solid #ffd0cb;
        }

        .cs-stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 18px;
        }

        .cs-stat-card {
            background: white;
            border: 1px solid #dfe2ec;
            border-radius: 4px;
            padding: 14px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .cs-stat-icon {
            width: 34px;
            height: 34px;
            border-radius: 6px;
            display: grid;
            place-items: center;
            color: #000666;
            background: #eef0ff;
        }

        .cs-stat-label {
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #767683;
        }

        .cs-stat-value {
            font-size: 18px;
            line-height: 1.1;
            font-weight: 900;
            color: #1a237e;
            margin-top: 3px;
        }

        .cs-card-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 14px;
        }

        .class-card {
            background: white;
            border: 1px solid #dfe2ec;
            border-top: 5px solid #000666;
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            min-height: 250px;
            transition: .16s ease;
        }

        .class-card:hover {
            box-shadow: 0 14px 30px rgba(16, 24, 40, .08);
            transform: translateY(-2px);
        }

        .class-card.is-extra-class {
            display: none;
        }

        .cs-card-grid.show-all-classes .class-card.is-extra-class {
            display: flex;
        }

        .class-card.card-green {
            border-top-color: #1b6d24;
        }

        .class-card.card-amber {
            border-top-color: #ffb865;
        }

        .class-card.card-rose {
            border-top-color: #ba1a1a;
        }

        .class-card-body {
            padding: 14px;
            flex: 1;
        }

        .class-top {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .class-title-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .class-code {
            width: 34px;
            height: 34px;
            border-radius: 4px;
            display: grid;
            place-items: center;
            font-weight: 900;
            color: #000666;
            background: #e0e0ff;
        }

        .card-green .class-code {
            background: #a0f399;
            color: #002204;
        }

        .card-amber .class-code {
            background: #ffddba;
            color: #2b1700;
        }

        .class-name {
            margin: 0;
            color: #000666;
            font-size: 13px;
            font-weight: 900;
        }

        .class-meta {
            color: #767683;
            font-size: 11px;
            margin-top: 3px;
        }

        .class-more {
            background: transparent;
            border: 0;
            color: #767683;
            cursor: pointer;
        }

        .teacher-box {
            display: flex;
            align-items: center;
            gap: 11px;
            background: #f9f9f9;
            border-radius: 4px;
            padding: 8px;
            margin-bottom: 12px;
        }

        .teacher-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #1a237e;
            color: white;
            display: grid;
            place-items: center;
            font-size: 10px;
            font-weight: 900;
        }

        .teacher-label {
            font-size: 9px;
            color: #767683;
            text-transform: uppercase;
            font-weight: 900;
            letter-spacing: .07em;
        }

        .teacher-name {
            font-size: 11px;
            color: #1a1c1c;
            font-weight: 900;
            margin-top: 2px;
        }

        .subjects-label {
            font-size: 9px;
            color: #767683;
            text-transform: uppercase;
            font-weight: 900;
            letter-spacing: .07em;
            margin-bottom: 9px;
        }

        .subject-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
        }

        .subject-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            border-radius: 4px;
            border: 1px solid #dce0ff;
            background: #eef0ff;
            color: #000666;
            font-size: 10px;
            font-weight: 900;
            padding: 4px 6px;
        }

        .chip-remove {
            border: 0;
            background: transparent;
            color: #ba1a1a;
            cursor: pointer;
            padding: 0;
            display: inline-flex;
        }

        .empty-subject {
            color: #9a9baa;
            font-size: 13px;
        }

        .class-actions {
            border-top: 1px solid #dfe2ec;
            padding: 10px;
            display: flex;
            gap: 8px;
        }

        .class-actions .cs-btn {
            flex: 1;
            padding: 8px 10px;
            font-size: 10px;
        }

        .add-class-card {
            border: 2px dashed #c6c5d4;
            border-radius: 6px;
            min-height: 250px;
            display: grid;
            place-items: center;
            background: rgba(255,255,255,.55);
            cursor: pointer;
            transition: .16s ease;
        }

        .add-class-card:hover {
            background: #eef0ff;
        }

        .add-class-content {
            text-align: center;
        }

        .add-class-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #eef0ff;
            color: #000666;
            display: grid;
            place-items: center;
            margin: 0 auto 10px;
        }

        .add-class-title {
            color: #000666;
            font-weight: 900;
            margin-bottom: 4px;
        }

        .add-class-subtitle {
            color: #767683;
            font-size: 11px;
        }

        .cs-view-all-row {
            display: flex;
            justify-content: center;
            margin-top: 14px;
        }

        .cs-view-all-row .cs-btn {
            min-width: 150px;
        }

        .subject-table-wrap {
            margin-top: 22px;
            background: white;
            border: 1px solid #dfe2ec;
            border-radius: 6px;
            overflow: hidden;
        }

        .subject-table-header {
            padding: 13px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #fbfcff;
            border-bottom: 1px solid #dfe2ec;
        }

        .subject-table-title {
            margin: 0;
            color: #1a237e;
            font-size: 13px;
            font-weight: 900;
        }

        .subject-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .subject-table th {
            background: #f9f9f9;
            color: #767683;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .07em;
            padding: 10px 16px;
            border-bottom: 1px solid #dfe2ec;
        }

        .subject-table td {
            padding: 12px 16px;
            border-bottom: 1px solid #f1f2f7;
            font-size: 12px;
        }

        .subject-code {
            font-weight: 900;
            color: #1a237e;
        }

        .dept-pill {
            background: #eef0ff;
            color: #000666;
            border-radius: 5px;
            padding: 4px 8px;
            font-size: 11px;
            font-weight: 900;
        }

        .table-action {
            border: 0;
            background: transparent;
            color: #000666;
            font-weight: 900;
            text-transform: uppercase;
            font-size: 11px;
            cursor: pointer;
        }

        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(16, 24, 40, .45);
            z-index: 100;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-backdrop.show {
            display: flex;
        }

        .cs-modal {
            width: min(520px, 100%);
            background: white;
            border-radius: 16px;
            box-shadow: 0 24px 60px rgba(16, 24, 40, .24);
            overflow: hidden;
        }

        .cs-modal-header {
            padding: 18px 20px;
            border-bottom: 1px solid #dfe2ec;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .cs-modal-title {
            margin: 0;
            color: #000666;
            font-size: 18px;
            font-weight: 900;
        }

        .modal-close {
            border: 0;
            background: #f6f7fb;
            width: 34px;
            height: 34px;
            border-radius: 8px;
            cursor: pointer;
        }

        .cs-form {
            padding: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 900;
            color: #454652;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            border: 1px solid #dfe2ec;
            border-radius: 9px;
            padding: 12px;
            font-family: inherit;
            outline: none;
        }

        .form-control:focus {
            border-color: #000666;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding-top: 5px;
        }

        @@media (max-width: 1100px) {
            .cs-stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .cs-card-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 760px) {
            .cs-page-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .cs-stats,
            .cs-card-grid {
                grid-template-columns: 1fr;
            }

            .subject-table {
                min-width: 760px;
            }

            .subject-table-wrap {
                overflow-x: auto;
            }
        }
    </style>
}

<div class="cs-page-header">
    <div>
        <h1 class="cs-title">Class & Subject Management</h1>
        <p class="cs-subtitle">Organize academic structures, assign class teachers, and map curriculum subjects.</p>
    </div>

    <div class="cs-header-actions">
        <a class="cs-btn cs-btn-secondary" href="@Url.Action("Index", "ClassSubjects")">
            <span class="material-symbols-outlined">filter_list</span>
            Filters
        </a>

        <button class="cs-btn cs-btn-primary" type="button" onclick="openModal('createClassModal')">
            <span class="material-symbols-outlined">add</span>
            Create New Class
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="cs-alert cs-alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="cs-alert cs-alert-error">@TempData["Error"]</div>
}

<div class="cs-stats">
    @foreach (var stat in Model.Stats)
    {
        <div class="cs-stat-card">
            <div class="cs-stat-icon">
                <span class="material-symbols-outlined">
                    @(stat.Label.Contains("Classes") ? "meeting_room" :
                      stat.Label.Contains("Subjects") ? "book" :
                      stat.Label.Contains("Teachers") ? "person_search" : "error")
                </span>
            </div>
            <div>
                <div class="cs-stat-label">@stat.Label</div>
                <div class="cs-stat-value">@stat.Value</div>
            </div>
        </div>
    }
</div>

@{
    var visibleClassCount = 3;
    var classIndex = 0;
}

<div class="cs-card-grid" id="classGrid">
    @foreach (var classCard in Model.ClassCards)
    {
        var cardVisibilityClass = classIndex >= visibleClassCount ? "is-extra-class" : string.Empty;
        classIndex++;

        <div class="class-card @CardAccent(classCard.AccentClass) @cardVisibilityClass">
            <div class="class-card-body">
                <div class="class-top">
                    <div class="class-title-wrap">
                        <div class="class-code">@InitialCode(classCard.Name)</div>
                        <div>
                            <h2 class="class-name">@classCard.Name</h2>
                            <div class="class-meta">Capacity @classCard.Capacity &bull; @classCard.StudentCount students</div>
                        </div>
                    </div>

                    <button class="class-more" type="button" onclick="openAssignTeacherModal('@classCard.Id', '@classCard.TeacherId')">
                        <span class="material-symbols-outlined">more_vert</span>
                    </button>
                </div>

                <div class="teacher-box">
                    <div class="teacher-avatar">@InitialCode(classCard.ClassTeacherName)</div>
                    <div>
                        <div class="teacher-label">Class Teacher</div>
                        <div class="teacher-name">@classCard.ClassTeacherName</div>
                    </div>
                </div>

                <div>
                    <div class="subjects-label">Linked Subjects (@classCard.SubjectCount)</div>

                    @if (classCard.Subjects.Any())
                    {
                        <div class="subject-chips">
                            @foreach (var subject in classCard.Subjects.Take(6))
                            {
                                <span class="subject-chip">
                                    @subject.Name

                                    <form asp-action="RemoveSubjectFromClass" asp-controller="ClassSubjects" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ClassId" value="@classCard.Id" />
                                        <input type="hidden" name="SubjectId" value="@subject.Id" />
                                        <button class="chip-remove" type="submit" title="Remove subject">
                                            <span class="material-symbols-outlined" style="font-size:14px;">close</span>
                                        </button>
                                    </form>
                                </span>
                            }

                            @if (classCard.Subjects.Count > 6)
                            {
                                <span class="subject-chip">+ @(classCard.Subjects.Count - 6) more</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-subject">No linked subjects yet.</div>
                    }
                </div>
            </div>

            <div class="class-actions">
                <button class="cs-btn cs-btn-green" type="button" onclick="openAddSubjectModal('@classCard.Id')">
                    <span class="material-symbols-outlined">add</span>
                    Add Subject
                </button>

                <button class="cs-btn cs-btn-secondary" type="button" onclick="openAssignTeacherModal('@classCard.Id', '@classCard.TeacherId')">
                    <span class="material-symbols-outlined">visibility</span>
                    View Profile
                </button>
            </div>
        </div>
    }

    <button class="add-class-card" type="button" onclick="openModal('createClassModal')">
        <div class="add-class-content">
            <div class="add-class-icon">
                <span class="material-symbols-outlined" style="font-size:32px;">add_circle</span>
            </div>
            <div class="add-class-title">Add New Class</div>
            <div class="add-class-subtitle">Configure a new grade or section</div>
        </div>
    </button>
</div>

@if (Model.ClassCards.Count > visibleClassCount)
{
    <div class="cs-view-all-row">
        <button class="cs-btn cs-btn-secondary" type="button" onclick="toggleAllClasses(this)">
            <span class="material-symbols-outlined">unfold_more</span>
            View All Classes
        </button>
    </div>
}

<div class="subject-table-wrap">
    <div class="subject-table-header">
        <h3 class="subject-table-title">Global Subject Registry</h3>

        <button class="table-action" type="button" onclick="openCreateSubjectModal()">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle;">add</span>
            Add Subject
        </button>
    </div>

    <table class="subject-table">
        <thead>
            <tr>
                <th>Subject Code</th>
                <th>Subject Name</th>
                <th>Active Classes</th>
                <th>Department</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.SubjectRows.Any())
            {
                @foreach (var subject in Model.SubjectRows)
                {
                    <tr>
                        <td class="subject-code">@subject.Code</td>
                        <td>@subject.Name</td>
                        <td>
                            @if (subject.ActiveClasses.Any())
                            {
                                @string.Join(", ", subject.ActiveClasses.Take(5))

                                @if (subject.ActiveClasses.Count > 5)
                                {
                                    <span> +@(subject.ActiveClasses.Count - 5) more</span>
                                }
                            }
                            else
                            {
                                <span>None</span>
                            }
                        </td>
                        <td>
                            <span class="dept-pill">@subject.Department</span>
                        </td>
                        <td style="text-align:right;">
                            <button class="table-action"
                                    type="button"
                                    data-id="@subject.Id"
                                    data-code="@subject.Code"
                                    data-name="@subject.Name"
                                    data-department="@subject.Department"
                                    onclick="openEditSubjectModalFromButton(this)">
                                Edit
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" style="text-align:center; color:#767683; padding:26px;">
                        No subjects yet. Add your first subject.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="createClassModal" class="modal-backdrop">
    <div class="cs-modal">
        <div class="cs-modal-header">
            <h3 class="cs-modal-title">Create Class</h3>
            <button class="modal-close" type="button" onclick="closeModal('createClassModal')">&times;</button>
        </div>

        <form class="cs-form" asp-action="SaveClass" asp-controller="ClassSubjects" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="Id" id="classId" />

            <div class="form-group">
                <label>Class Name</label>
                <input class="form-control" name="Name" id="className" placeholder="Example: Primary One" required />
            </div>

            <div class="form-group">
                <label>Capacity</label>
                <input class="form-control" name="Capacity" id="classCapacity" type="number" min="1" value="40" required />
            </div>

            <div class="modal-actions">
                <button class="cs-btn cs-btn-secondary" type="button" onclick="closeModal('createClassModal')">Cancel</button>
                <button class="cs-btn cs-btn-primary" type="submit">Save Class</button>
            </div>
        </form>
    </div>
</div>

<div id="createSubjectModal" class="modal-backdrop">
    <div class="cs-modal">
        <div class="cs-modal-header">
            <h3 class="cs-modal-title" id="subjectModalTitle">Create Subject</h3>
            <button class="modal-close" type="button" onclick="closeModal('createSubjectModal')">&times;</button>
        </div>

        <form class="cs-form" asp-action="SaveSubject" asp-controller="ClassSubjects" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="Id" id="subjectId" />

            <div class="form-group">
                <label>Subject Code</label>
                <input class="form-control" name="Code" id="subjectCode" placeholder="Example: MAT-001" required />
            </div>

            <div class="form-group">
                <label>Subject Name</label>
                <input class="form-control" name="Name" id="subjectName" placeholder="Example: Mathematics" required />
            </div>

            <div class="form-group">
                <label>Department</label>
                <input class="form-control" name="Department" id="subjectDepartment" placeholder="Example: STEM" required />
            </div>

            <div class="modal-actions">
                <button class="cs-btn cs-btn-secondary" type="button" onclick="closeModal('createSubjectModal')">Cancel</button>
                <button class="cs-btn cs-btn-primary" type="submit">Save Subject</button>
            </div>
        </form>
    </div>
</div>

<div id="assignTeacherModal" class="modal-backdrop">
    <div class="cs-modal">
        <div class="cs-modal-header">
            <h3 class="cs-modal-title">Assign Class Teacher</h3>
            <button class="modal-close" type="button" onclick="closeModal('assignTeacherModal')">&times;</button>
        </div>

        <form class="cs-form" asp-action="AssignTeacher" asp-controller="ClassSubjects" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="ClassId" id="assignTeacherClassId" />

            <div class="form-group">
                <label>Teacher</label>
                <select class="form-control" name="TeacherId" id="assignTeacherId">
                    <option value="">No class teacher</option>
                    @foreach (SelectListItem teacher in ViewBag.Teachers)
                    {
                        <option value="@teacher.Value">@teacher.Text</option>
                    }
                </select>
            </div>

            <div class="modal-actions">
                <button class="cs-btn cs-btn-secondary" type="button" onclick="closeModal('assignTeacherModal')">Cancel</button>
                <button class="cs-btn cs-btn-primary" type="submit">Save Assignment</button>
            </div>
        </form>
    </div>
</div>

<div id="addSubjectModal" class="modal-backdrop">
    <div class="cs-modal">
        <div class="cs-modal-header">
            <h3 class="cs-modal-title">Add Subject To Class</h3>
            <button class="modal-close" type="button" onclick="closeModal('addSubjectModal')">&times;</button>
        </div>

        <form class="cs-form" asp-action="AddSubjectToClass" asp-controller="ClassSubjects" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="ClassId" id="addSubjectClassId" />

            <div class="form-group">
                <label>Subject</label>
                <select class="form-control" name="SubjectId" required>
                    <option value="">Select subject</option>
                    @foreach (SelectListItem subject in ViewBag.Subjects)
                    {
                        <option value="@subject.Value">@subject.Text</option>
                    }
                </select>
            </div>

            <div class="modal-actions">
                <button class="cs-btn cs-btn-secondary" type="button" onclick="closeModal('addSubjectModal')">Cancel</button>
                <button class="cs-btn cs-btn-primary" type="submit">Link Subject</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) {
            document.getElementById(id).classList.add('show');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
        }

        function toggleAllClasses(button) {
            const grid = document.getElementById('classGrid');
            const isShowingAll = grid.classList.toggle('show-all-classes');
            button.querySelector('.material-symbols-outlined').innerText = isShowingAll ? 'unfold_less' : 'unfold_more';
            button.lastChild.textContent = isShowingAll ? ' Show Fewer Classes' : ' View All Classes';
        }

        function openAddSubjectModal(classId) {
            document.getElementById('addSubjectClassId').value = classId;
            openModal('addSubjectModal');
        }

        function openAssignTeacherModal(classId, teacherId) {
            document.getElementById('assignTeacherClassId').value = classId;
            document.getElementById('assignTeacherId').value = teacherId && teacherId !== 'null' ? teacherId : '';
            openModal('assignTeacherModal');
        }

        function openCreateSubjectModal() {
            document.getElementById('subjectModalTitle').innerText = 'Create Subject';
            document.getElementById('subjectId').value = '';
            document.getElementById('subjectCode').value = '';
            document.getElementById('subjectName').value = '';
            document.getElementById('subjectDepartment').value = '';
            openModal('createSubjectModal');
        }

        function openEditSubjectModalFromButton(button) {
            document.getElementById('subjectModalTitle').innerText = 'Edit Subject';
            document.getElementById('subjectId').value = button.dataset.id;
            document.getElementById('subjectCode').value = button.dataset.code;
            document.getElementById('subjectName').value = button.dataset.name;
            document.getElementById('subjectDepartment').value = button.dataset.department;
            openModal('createSubjectModal');
        }

        document.addEventListener('click', function (event) {
            if (event.target.classList.contains('modal-backdrop')) {
                event.target.classList.remove('show');
            }
        });
    </script>
}
