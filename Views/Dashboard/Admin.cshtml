@model School_Management_System.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .dash-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 18px;
            margin-bottom: 20px;
        }

        .dash-title {
            margin: 0;
            font-size: 22px;
            line-height: 1.2;
            color: #000666;
            font-weight: 800;
            letter-spacing: -.02em;
        }

        .dash-subtitle {
            margin: 6px 0 0;
            color: #767683;
            font-size: 12px;
        }

        .dash-btn {
            border: 0;
            border-radius: 8px;
            padding: 9px 14px;
            background: #000666;
            color: #fff;
            font-family: inherit;
            font-size: 12px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .dash-stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 18px;
        }

        .dash-stat {
            background: #fff;
            border: 1px solid #dfe2ec;
            border-top: 4px solid #000666;
            border-radius: 8px;
            padding: 16px;
            min-height: 118px;
        }

        .dash-stat.green { border-top-color: #1b6d24; }
        .dash-stat.slate { border-top-color: #64748b; }
        .dash-stat.amber { border-top-color: #b76400; }

        .dash-stat-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .dash-stat-icon {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            display: grid;
            place-items: center;
            background: #eef0ff;
            color: #000666;
        }

        .dash-stat.green .dash-stat-icon {
            background: #e8f8ea;
            color: #1b6d24;
        }

        .dash-stat.slate .dash-stat-icon {
            background: #f1f5f9;
            color: #64748b;
        }

        .dash-stat.amber .dash-stat-icon {
            background: #fff4df;
            color: #b76400;
        }

        .dash-badge {
            border-radius: 999px;
            background: #eef0ff;
            color: #000666;
            padding: 4px 9px;
            font-size: 10px;
            font-weight: 900;
        }

        .dash-stat-label {
            color: #1a237e;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .08em;
            font-weight: 900;
        }

        .dash-stat-value {
            margin-top: 4px;
            font-size: 26px;
            line-height: 1.1;
            font-weight: 900;
            color: #111827;
        }

        .dash-stat-sub {
            color: #8b8fa3;
            font-size: 11px;
            margin-top: 4px;
        }

        .dash-grid {
            display: grid;
            grid-template-columns: minmax(0, 2fr) minmax(320px, 1fr);
            gap: 14px;
        }

        .dash-panel {
            background: #fff;
            border: 1px solid #dfe2ec;
            border-radius: 8px;
            overflow: hidden;
        }

        .dash-panel-head {
            padding: 13px 16px;
            border-bottom: 1px solid #dfe2ec;
            background: #fbfcff;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .dash-panel-title {
            margin: 0;
            color: #1a237e;
            font-size: 13px;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .activity-table {
            width: 100%;
            border-collapse: collapse;
        }

        .activity-table th {
            background: #f9f9f9;
            color: #767683;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .07em;
            padding: 10px 16px;
            text-align: left;
        }

        .activity-table td {
            border-top: 1px solid #f1f2f7;
            padding: 11px 16px;
            font-size: 12px;
            vertical-align: middle;
        }

        .activity-user {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .activity-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #1a237e;
            color: #fff;
            display: grid;
            place-items: center;
            font-size: 12px;
            font-weight: 900;
        }

        .status-pill {
            border-radius: 999px;
            padding: 4px 9px;
            font-size: 11px;
            font-weight: 900;
            background: #eef0ff;
            color: #000666;
            white-space: nowrap;
        }

        .status-pill.verified {
            background: #e8f8ea;
            color: #1b6d24;
        }

        .status-pill.action {
            background: #ffefed;
            color: #ba1a1a;
        }

        .status-pill.pending {
            background: #fff4df;
            color: #b76400;
        }

        .pulse-body {
            padding: 14px;
        }

        .pulse-item {
            margin-bottom: 18px;
        }

        .pulse-label {
            display: flex;
            justify-content: space-between;
            color: #454652;
            font-size: 12px;
            margin-bottom: 8px;
        }

        .pulse-track {
            height: 8px;
            border-radius: 999px;
            overflow: hidden;
            background: #eef0ff;
        }

        .pulse-fill {
            height: 100%;
            border-radius: 999px;
            background: #1b6d24;
        }

        .pulse-fill.blue {
            background: #000666;
        }

        .event-panel {
            margin-top: 14px;
            background: #1a237e;
            border-radius: 8px;
            color: #fff;
            padding: 16px;
        }

        .event-title {
            font-size: 13px;
            font-weight: 900;
            margin-bottom: 14px;
        }

        .event-item {
            display: flex;
            gap: 12px;
            margin-bottom: 12px;
        }

        .event-date {
            min-width: 44px;
            border-radius: 6px;
            background: rgba(255,255,255,.12);
            text-align: center;
            padding: 7px;
        }

        .event-date span {
            display: block;
            font-size: 10px;
            color: rgba(255,255,255,.62);
            font-weight: 900;
        }

        .event-date strong {
            font-size: 18px;
        }

        .event-name {
            font-weight: 800;
            font-size: 13px;
        }

        .event-meta {
            color: rgba(255,255,255,.65);
            font-size: 12px;
            margin-top: 2px;
        }

        @@media (max-width: 1100px) {
            .dash-stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .dash-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 720px) {
            .dash-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .dash-stats {
                grid-template-columns: 1fr;
            }

            .activity-table {
                min-width: 720px;
            }

            .dash-panel {
                overflow-x: auto;
            }
        }
    </style>
}

<div class="dash-header">
    <div>
        <h1 class="dash-title">Dashboard</h1>
        <p class="dash-subtitle">Welcome back. Live student, teacher, class, and finance activity appears here.</p>
    </div>
    <a class="dash-btn" href="@Url.Action("Index", "ClassSubjects")">
        <span class="material-symbols-outlined">fact_check</span>
        Manage Classes
    </a>
</div>

<div class="dash-stats">
    <div class="dash-stat">
        <div class="dash-stat-top">
            <div class="dash-stat-icon"><span class="material-symbols-outlined">groups</span></div>
            <span class="dash-badge">Live</span>
        </div>
        <div class="dash-stat-label">Total Students</div>
        <div class="dash-stat-value">@Model.TotalStudents.ToString("N0")</div>
        <div class="dash-stat-sub">Across @Model.GradeLevels grade levels</div>
    </div>

    <div class="dash-stat green">
        <div class="dash-stat-top">
            <div class="dash-stat-icon"><span class="material-symbols-outlined">badge</span></div>
            <span class="dash-badge">Live</span>
        </div>
        <div class="dash-stat-label">Total Teachers</div>
        <div class="dash-stat-value">@Model.TotalTeachers.ToString("N0")</div>
        <div class="dash-stat-sub">@Model.StudentRatio student ratio</div>
    </div>

    <div class="dash-stat slate">
        <div class="dash-stat-top">
            <div class="dash-stat-icon"><span class="material-symbols-outlined">meeting_room</span></div>
            <span class="dash-badge">Stable</span>
        </div>
        <div class="dash-stat-label">Total Classes</div>
        <div class="dash-stat-value">@Model.TotalClasses.ToString("N0")</div>
        <div class="dash-stat-sub">Room occupancy: @Model.RoomOccupancyPercent%</div>
    </div>

    <div class="dash-stat amber">
        <div class="dash-stat-top">
            <div class="dash-stat-icon"><span class="material-symbols-outlined">payments</span></div>
            <span class="dash-badge">Finance</span>
        </div>
        <div class="dash-stat-label">Fees Collected</div>
        <div class="dash-stat-value">@Model.TotalFeesCollected.ToString("N0")</div>
        <div class="dash-stat-sub">@Model.MonthlyGoalPercent% of monthly goal</div>
    </div>
</div>

<div class="dash-grid">
    <div class="dash-panel">
        <div class="dash-panel-head">
            <h2 class="dash-panel-title">
                <span class="material-symbols-outlined">history</span>
                Recent Activity
            </h2>
        </div>

        <table class="activity-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Action</th>
                    <th>Time</th>
                    <th>Status</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.RecentActivity.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align:center;padding:28px;color:#767683;">
                            No activity yet. It will appear here as you use the system.
                        </td>
                    </tr>
                }

                @foreach (var log in Model.RecentActivity)
                {
                    var initStr = log.UserName.Length >= 2
                        ? log.UserName[..2].ToUpper()
                        : log.UserName.ToUpper();
                    var elapsed = DateTime.Now - log.Timestamp;
                    var timeStr = elapsed.TotalMinutes < 2 ? "Just now"
                        : elapsed.TotalMinutes < 60 ? $"{(int)elapsed.TotalMinutes} mins ago"
                        : elapsed.TotalHours < 24 ? $"{(int)elapsed.TotalHours} hrs ago"
                        : $"{(int)elapsed.TotalDays} days ago";
                    var pillClass = log.Status switch
                    {
                        "Verified" => "verified",
                        "Action Req." => "action",
                        "Pending" => "pending",
                        _ => ""
                    };

                    <tr>
                        <td>
                            <div class="activity-user">
                                <div class="activity-avatar">@initStr</div>
                                <div>
                                    <div style="font-weight:900;">@log.UserName</div>
                                    <div style="font-size:12px;color:#767683;">@log.UserRole</div>
                                </div>
                            </div>
                        </td>
                        <td>@log.Action</td>
                        <td style="color:#767683;white-space:nowrap;">@timeStr</td>
                        <td><span class="status-pill @pillClass">@log.Status</span></td>
                        <td style="text-align:right;">
                            @if (log.RelatedUserId.HasValue)
                            {
                                <a href="@Url.Action("Details", "Students", new { id = log.RelatedUserId.Value })" style="color:#000666;font-weight:900;font-size:12px;">View Profile</a>
                            }
                            else
                            {
                                <span style="color:#c6c5d4;">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div>
        <div class="dash-panel">
            <div class="dash-panel-head">
                <h2 class="dash-panel-title">
                    <span class="material-symbols-outlined">monitoring</span>
                    Academic Pulse
                </h2>
            </div>
            <div class="pulse-body">
                <div class="pulse-item">
                    <div class="pulse-label">
                        <span>Daily Attendance</span>
                        <strong>@Model.DailyAttendancePercent%</strong>
                    </div>
                    <div class="pulse-track">
                        <div class="pulse-fill" style="width:@Model.DailyAttendancePercent%"></div>
                    </div>
                </div>

                <div class="pulse-item" style="margin-bottom:0;">
                    <div class="pulse-label">
                        <span>Staff Availability</span>
                        <strong>@Model.StaffAvailabilityPercent%</strong>
                    </div>
                    <div class="pulse-track">
                        <div class="pulse-fill blue" style="width:@Model.StaffAvailabilityPercent%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="event-panel">
            <div class="event-title">Upcoming Events</div>
            @foreach (var ev in Model.UpcomingEvents)
            {
                <div class="event-item">
                    <div class="event-date">
                        <span>@ev.Month</span>
                        <strong>@ev.Day</strong>
                    </div>
                    <div>
                        <div class="event-name">@ev.Title</div>
                        <div class="event-meta">@ev.Location &bull; @ev.Time</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
