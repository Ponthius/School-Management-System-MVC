@model School_Management_System.Models.ViewModels.StudentEditViewModel
@{
    ViewData["Title"] = "Edit Student";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-4">
        <a href="/Students" class="text-xs text-indigo-600 hover:underline flex items-center gap-1">
            <i class="bi bi-arrow-left"></i> Back to Students
        </a>
        <div class="text-indigo-700 text-sm font-semibold mt-1">Edit Student</div>
    </div>

    <form asp-action="Edit" asp-controller="Students"
          asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ExistingPhoto" />

        <!-- Personal info -->
        <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
            <div class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Personal Information</div>
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="text-xs font-medium text-gray-600 block mb-1">Full Name</label>
                    <input asp-for="FullName"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                    outline-none focus:border-indigo-400 bg-gray-50" />
                    <span asp-validation-for="FullName" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Gender</label>
                    <select asp-for="Gender"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                        outline-none focus:border-indigo-400 bg-gray-50">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Date of Birth</label>
                    <input asp-for="DOB" type="date"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                    outline-none focus:border-indigo-400 bg-gray-50" />
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Class</label>
                    <select asp-for="ClassId" asp-items="ViewBag.Classes"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                        outline-none focus:border-indigo-400 bg-gray-50">
                    </select>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Status</label>
                    <select asp-for="Status"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                        outline-none focus:border-indigo-400 bg-gray-50">
                        <option value="New">New</option>
                        <option value="Continuing">Continuing</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Term</label>
                    <select asp-for="Term"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                        outline-none focus:border-indigo-400 bg-gray-50">
                        <option value="Term 1">Term 1</option>
                        <option value="Term 2">Term 2</option>
                        <option value="Term 3">Term 3</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Guardian Name</label>
                    <input asp-for="GuardianName"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                    outline-none focus:border-indigo-400 bg-gray-50" />
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Guardian Contact</label>
                    <input asp-for="GuardianContact"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                    outline-none focus:border-indigo-400 bg-gray-50" />
                </div>
            </div>
        </div>

        <!-- Photo -->
        <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
            <div class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Photo</div>
            <div class="flex items-center gap-4">
                <img id="photoPreview" src="@Model.ExistingPhoto"
                     onerror="this.src='/images/default-avatar.png'"
                     class="w-16 h-16 rounded-full object-cover border-2 border-gray-200" />
                <div>
                    <input type="file" asp-for="Photo" accept="image/*"
                           class="text-xs" onchange="previewPhoto(this)" />
                    <div class="text-xs text-gray-400 mt-1">Leave blank to keep existing photo</div>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3">
            <a href="/Students" class="text-xs px-5 py-2 border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600">
                Cancel
            </a>
            <button type="submit"
                    class="text-xs px-6 py-2 bg-indigo-800 text-white rounded-lg hover:bg-indigo-900">
                <i class="bi bi-check-lg me-1"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function previewPhoto(input) {
          if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
          }
        }
    </script>
}