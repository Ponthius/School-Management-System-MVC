@model School_Management_System.Models.ViewModels.StudentCreateViewModel
@{
    ViewData["Title"] = "Add New Student";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-4">
        <a href="/Students" class="text-xs text-indigo-600 hover:underline flex items-center gap-1">
            <i class="bi bi-arrow-left"></i> Back to Students
        </a>
        <div class="text-indigo-700 text-sm font-semibold mt-1">Add New Student</div>
        <div class="text-gray-400 text-xs">Fill in all details. Admin creates the student's login credentials.</div>
    </div>

    <form asp-action="Create" asp-controller="Students"
          method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <!-- Login credentials -->
        <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
            <div class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3 flex items-center gap-2">
                <i class="bi bi-key-fill text-indigo-500"></i> Login Credentials
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Username</label>
                    <input asp-for="Username" class="w-full border border-gray-200 rounded-lg px-3 py-2
                    text-sm outline-none focus:border-indigo-400 bg-gray-50"
                           placeholder="e.g. john.doe2025" />
                    <span asp-validation-for="Username" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Password</label>
                    <input asp-for="Password" type="password"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2
                    text-sm outline-none focus:border-indigo-400 bg-gray-50"
                           placeholder="Min 6 characters" />
                    <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
                </div>
            </div>
        </div>

        <!-- Personal info -->
        <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
            <div class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3 flex items-center gap-2">
                <i class="bi bi-person-fill text-indigo-500"></i> Personal Information
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="text-xs font-medium text-gray-600 block mb-1">Full Name</label>
                    <input asp-for="FullName"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2
                    text-sm outline-none focus:border-indigo-400 bg-gray-50"
                           placeholder="First and last name" />
                    <span asp-validation-for="FullName" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Gender</label>
                    <select asp-for="Gender"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2
                        text-sm outline-none focus:border-indigo-400 bg-gray-50">
                        <option value="">— Select —</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Date of Birth</label>
                    <input asp-for="DOB" type="date"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2
                    text-sm outline-none focus:border-indigo-400 bg-gray-50" />
                    <span asp-validation-for="DOB" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Class</label>
                    <select asp-for="ClassId" asp-items="ViewBag.Classes"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2
                        text-sm outline-none focus:border-indigo-400 bg-gray-50">
                        <option value="">Select class</option>
                    </select>
                    <span asp-validation-for="ClassId" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Status</label>
                    <select asp-for="Status"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2
                        text-sm outline-none focus:border-indigo-400 bg-gray-50">
                        <option value="New">New</option>
                        <option value="Continuing">Continuing</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Term</label>
                    <select asp-for="Term"
                            class="w-full border border-gray-200 rounded-lg px-3 py-2
                        text-sm outline-none focus:border-indigo-400 bg-gray-50">
                        <option value="">— Select —</option>
                        <option value="Term 1">Term 1</option>
                        <option value="Term 2">Term 2</option>
                        <option value="Term 3">Term 3</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Guardian info -->
        <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
            <div class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3 flex items-center gap-2">
                <i class="bi bi-people-fill text-indigo-500"></i> Guardian Information
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Guardian Name</label>
                    <input asp-for="GuardianName"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2
                    text-sm outline-none focus:border-indigo-400 bg-gray-50"
                           placeholder="Full name" />
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Guardian Contact</label>
                    <input asp-for="GuardianContact"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2
                    text-sm outline-none focus:border-indigo-400 bg-gray-50"
                           placeholder="+256 700 000000" />
                </div>
            </div>
        </div>

        <!-- Photo upload -->
        <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
            <div class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3 flex items-center gap-2">
                <i class="bi bi-camera-fill text-indigo-500"></i> Student Photo
            </div>
            <div class="flex items-center gap-4">
                <img id="photoPreview" src="/images/default-avatar.png"
                     class="w-16 h-16 rounded-full object-cover border-2 border-gray-200" />
                <div>
                    <input type="file" asp-for="Photo" accept="image/*"
                           class="text-xs text-gray-600"
                           onchange="previewPhoto(this)" />
                    <div class="text-xs text-gray-400 mt-1">JPG, PNG — max 2MB</div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex justify-end gap-3">
            <a href="/Students/Index"
                   class="text-xs px-5 py-2 border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600">
                Cancel
            </a>
            <button type="submit"
                    class="text-xs px-6 py-2 bg-indigo-800 text-white rounded-lg hover:bg-indigo-900">
                <i class="bi bi-check-lg me-1"></i> Save Student
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        function previewPhoto(input) {
          if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
          }
        }
    </script>
}