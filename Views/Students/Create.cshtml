@model School_Management_System.Models.ViewModels.StudentCreateViewModel
@{
    ViewData["Title"] = "Add New Student";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
<style>
    .student-create {
        --primary: #000666;
        --border: #dfe2ec;
        --muted: #667085;
    }

    .student-create-wrap { max-width: 980px; }

    .student-create-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .back-link {
        color: var(--primary);
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-size: .82rem;
        font-weight: 800;
        margin-bottom: .45rem;
    }

    .student-create-title {
        margin: 0;
        color: var(--primary);
        font-size: 1.45rem;
        font-weight: 900;
        letter-spacing: -.02em;
    }

    .student-create-subtitle {
        margin: .35rem 0 0;
        color: var(--muted);
        font-size: .86rem;
    }

    .student-form { display: grid; gap: 1rem; }

    .form-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: .5rem;
        box-shadow: 0 1px 2px rgba(16, 24, 40, .04);
        overflow: hidden;
    }

    .form-card-head {
        padding: .85rem 1rem;
        background: #fbfcff;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: .5rem;
        color: var(--primary);
        font-size: .76rem;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .form-card-body { padding: 1rem; }

    .field-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .85rem;
    }

    .field.full { grid-column: 1 / -1; }

    .field label {
        display: block;
        color: #344054;
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .07em;
        margin-bottom: .35rem;
    }

    .field input,
    .field select {
        width: 100%;
        height: 2.45rem;
        border: 1px solid #cfd5e3;
        background: #fff;
        border-radius: .28rem;
        padding: .48rem .65rem;
        font-size: .84rem;
        color: #111827;
        outline: none;
    }

    .field input:focus,
    .field select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(0, 6, 102, .08);
    }

    .validation-text {
        color: #ba1a1a;
        display: block;
        font-size: .72rem;
        font-weight: 700;
        margin-top: .25rem;
    }

    .photo-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .photo-preview {
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e5e7eb;
        background: #f8fafc;
    }

    .hint {
        color: #8a93a5;
        font-size: .76rem;
        margin-top: .35rem;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        flex-wrap: wrap;
        margin-top: .25rem;
    }

    .student-btn {
        min-height: 2.35rem;
        border: 0;
        border-radius: .28rem;
        padding: .55rem 1rem;
        font-size: .82rem;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        text-decoration: none;
        cursor: pointer;
    }

    .student-btn.primary { background: var(--primary); color: #fff; }
    .student-btn.ghost { background: #fff; color: var(--primary); border: 1px solid var(--border); }

    @@media (max-width: 760px) {
        .field-grid { grid-template-columns: 1fr; }
    }
</style>
}

<div class="student-create student-create-wrap">
    <div class="student-create-head">
        <div>
            <a href="@Url.Action("Index", "Students")" class="back-link">
                <i class="bi bi-arrow-left"></i>
                Back to Students
            </a>
            <h1 class="student-create-title">Add New Student</h1>
            <p class="student-create-subtitle">Fill in all details. Admin creates the student's login credentials.</p>
        </div>
    </div>

    <form class="student-form" asp-action="Create" asp-controller="Students" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <section class="form-card">
            <div class="form-card-head"><i class="bi bi-key-fill"></i> Login Credentials</div>
            <div class="form-card-body">
                <div class="field-grid">
                    <div class="field">
                        <label asp-for="Username">Username</label>
                        <input asp-for="Username" placeholder="e.g. john.doe2025" />
                        <span asp-validation-for="Username" class="validation-text"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password" type="password" placeholder="Min 6 characters" />
                        <span asp-validation-for="Password" class="validation-text"></span>
                    </div>
                </div>
            </div>
        </section>

        <section class="form-card">
            <div class="form-card-head"><i class="bi bi-person-fill"></i> Personal Information</div>
            <div class="form-card-body">
                <div class="field-grid">
                    <div class="field full">
                        <label asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" placeholder="First and last name" />
                        <span asp-validation-for="FullName" class="validation-text"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Gender">Gender</label>
                        <select asp-for="Gender">
                            <option value="">Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="validation-text"></span>
                    </div>
                    <div class="field">
                        <label asp-for="DOB">Date of Birth</label>
                        <input asp-for="DOB" type="date" />
                        <span asp-validation-for="DOB" class="validation-text"></span>
                    </div>
                    <div class="field">
                        <label asp-for="ClassId">Class</label>
                        <select asp-for="ClassId" asp-items="ViewBag.Classes">
                            <option value="">Select class</option>
                        </select>
                        <span asp-validation-for="ClassId" class="validation-text"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Status">Status</label>
                        <select asp-for="Status">
                            <option value="New">New</option>
                            <option value="Continuing">Continuing</option>
                        </select>
                    </div>
                    <div class="field">
                        <label asp-for="Term">Term</label>
                        <select asp-for="Term">
                            <option value="">Select term</option>
                            <option value="Term 1">Term 1</option>
                            <option value="Term 2">Term 2</option>
                            <option value="Term 3">Term 3</option>
                        </select>
                    </div>
                </div>
            </div>
        </section>

        <section class="form-card">
            <div class="form-card-head"><i class="bi bi-people-fill"></i> Guardian Information</div>
            <div class="form-card-body">
                <div class="field-grid">
                    <div class="field">
                        <label asp-for="GuardianName">Guardian Name</label>
                        <input asp-for="GuardianName" placeholder="Full name" />
                    </div>
                    <div class="field">
                        <label asp-for="GuardianContact">Guardian Contact</label>
                        <input asp-for="GuardianContact" placeholder="+256 700 000000" />
                    </div>
                </div>
            </div>
        </section>

        <section class="form-card">
            <div class="form-card-head"><i class="bi bi-camera-fill"></i> Student Photo</div>
            <div class="form-card-body">
                <div class="photo-row">
                    <img id="photoPreview" src="/images/default-avatar.png" class="photo-preview" alt="Student preview" />
                    <div class="field" style="min-width:260px;">
                        <label asp-for="Photo">Upload Photo</label>
                        <input asp-for="Photo" type="file" accept="image/*" onchange="previewPhoto(this)" />
                        <div class="hint">JPG or PNG recommended.</div>
                    </div>
                </div>
            </div>
        </section>

        <div class="form-actions">
            <a href="@Url.Action("Index", "Students")" class="student-btn ghost">Cancel</a>
            <button type="submit" class="student-btn primary">
                <i class="bi bi-check-lg"></i>
                Save Student
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
