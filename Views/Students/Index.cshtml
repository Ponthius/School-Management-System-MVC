@model List<School_Management_System.Models.Student>
@{
    ViewData["Title"] = "Student Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int currentPage = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    int total = ViewBag.Total;
    string search = ViewBag.Search ?? "";
}

<!-- Page header -->
<div class="flex items-start justify-between mb-4">
  <div>
    <div class="text-indigo-700 text-sm font-semibold">Student Management</div>
    <div class="text-gray-500 text-xs">Manage registrations, academic tracks, and student records.</div>
  </div>
  <a href="/Students/Create"
     class="flex items-center gap-1 bg-indigo-800 text-white text-xs font-medium
            px-4 py-2 rounded-lg hover:bg-indigo-900 transition">
    <i class="bi bi-plus-lg"></i> Add New Student
  </a>
</div>

<!-- Success toast -->
@if (TempData["Success"] != null)
{
  <div class="mb-3 bg-green-50 border border-green-200 text-green-700 text-xs
              rounded-lg px-4 py-2 flex items-center gap-2">
    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
  </div>
}

<!-- Stat cards -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
  <div class="bg-white rounded-xl border border-gray-200 p-4 flex items-center gap-3">
    <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-content-center">
      <i class="bi bi-people-fill text-indigo-600 text-lg mx-auto"></i>
    </div>
    <div>
      <div class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Total Students</div>
      <div class="text-xl font-extrabold text-gray-900">@ViewBag.TotalStudents.ToString("N0")</div>
    </div>
  </div>
  <div class="bg-white rounded-xl border border-l-4 border-l-green-400 border-gray-200 p-4 flex items-center gap-3">
    <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-content-center">
      <i class="bi bi-person-plus-fill text-green-600 text-lg mx-auto"></i>
    </div>
    <div>
      <div class="text-xs text-gray-500 uppercase tracking-wide font-semibold">New Enrolments</div>
      <div class="text-xl font-extrabold text-gray-900">@ViewBag.NewEnrolments</div>
    </div>
  </div>
  <div class="bg-white rounded-xl border border-l-4 border-l-amber-400 border-gray-200 p-4 flex items-center gap-3">
    <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-content-center">
      <i class="bi bi-exclamation-triangle-fill text-amber-500 text-lg mx-auto"></i>
    </div>
    <div>
      <div class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Attendance Alerts</div>
      <div class="text-xl font-extrabold text-gray-900">@ViewBag.AttendanceAlerts</div>
    </div>
  </div>
  <div class="bg-white rounded-xl border border-l-4 border-l-red-400 border-gray-200 p-4 flex items-center gap-3">
    <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-content-center">
      <i class="bi bi-cash-stack text-red-500 text-lg mx-auto"></i>
    </div>
    <div>
      <div class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Unpaid Fees</div>
      <div class="text-xl font-extrabold text-gray-900">@ViewBag.UnpaidFees</div>
    </div>
  </div>
</div>

<!-- Table panel -->
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-4">

  <!-- Filter bar -->
  <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
    <form method="get" action="/Students" class="flex items-center gap-2 flex-1">
      <div class="relative">
        <i class="bi bi-funnel absolute left-2 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
        <input name="search" value="@search"
               placeholder="Filter by name..."
               class="pl-7 pr-3 py-1.5 text-xs border border-gray-200 rounded-md
                      bg-gray-50 outline-none focus:border-indigo-400 w-44"/>
      </div>
      <select name="classId"
              class="text-xs border border-gray-200 rounded-md px-2 py-1.5
                     bg-gray-50 outline-none focus:border-indigo-400">
        <option value="">All Classes</option>
                @foreach (SelectListItem item in ViewBag.Classes)
                {
                    if (item.Selected)
                    {
                        <option value="@item.Value" selected>@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
      </select>
      <button type="submit"
              class="text-xs bg-indigo-700 text-white px-3 py-1.5 rounded-md hover:bg-indigo-800">
        Search
      </button>
      @if (!string.IsNullOrEmpty(search))
      {
        <a href="/Students" class="text-xs text-gray-400 hover:text-red-500">Clear</a>
      }
    </form>
        <div class="text-xs text-gray-400 ml-auto">
            Showing @((currentPage - 1) * 10 + 1)–@(Math.Min(currentPage * 10, total)) of @total
        </div>
  </div>

  <!-- Table -->
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-gray-50 text-gray-500 text-xs font-semibold uppercase tracking-wide">
        <th class="px-4 py-3 text-left">Photo</th>
        <th class="px-4 py-3 text-left">Full Name</th>
        <th class="px-4 py-3 text-left">Class</th>
        <th class="px-4 py-3 text-left">Gender</th>
        <th class="px-4 py-3 text-left">Status</th>
        <th class="px-4 py-3 text-left">Actions</th>
      </tr>
    </thead>
    <tbody>
    @if (!Model.Any())
    {
      <tr>
        <td colspan="6" class="text-center py-10 text-gray-400 text-xs">
          No students found. <a href="/Students/Create" class="text-indigo-600 hover:underline">Add one now.</a>
        </td>
      </tr>
    }
    @foreach (var s in Model)
    {
      <tr class="border-t border-gray-100 hover:bg-gray-50 transition">
        <td class="px-4 py-3">
          <img src="@s.PhotoPath"
               onerror="this.src='/images/default-avatar.png'"
               class="w-9 h-9 rounded-full object-cover border border-gray-200"/>
        </td>
        <td class="px-4 py-3">
          <a href="/Students/Details/@s.Id"
             class="font-semibold text-indigo-700 hover:underline text-sm">
            @s.FullName
          </a>
        </td>
        <td class="px-4 py-3 text-gray-600 text-xs">@(s.Class?.Name ?? "—")</td>
        <td class="px-4 py-3 text-gray-600 text-xs">@s.Gender</td>
        <td class="px-4 py-3">
          <span class="status-pill @(s.Status=="Continuing"?"s-continuing":"s-new")">
            @s.Status.ToUpper()
          </span>
        </td>
        <td class="px-4 py-3">
          <div class="flex items-center gap-2">
            <a href="/Students/Details/@s.Id"
               class="text-gray-400 hover:text-indigo-600" title="View">
              <i class="bi bi-eye"></i>
            </a>
            <a href="/Students/Edit/@s.Id"
               class="text-gray-400 hover:text-amber-500" title="Edit">
              <i class="bi bi-pencil"></i>
            </a>
            <button onclick="confirmDelete(@s.Id, '@s.FullName')"
                    class="text-gray-400 hover:text-red-500 border-0 bg-transparent" title="Delete">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </td>
      </tr>
    }
    </tbody>
  </table>
    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="flex items-center justify-between px-4 py-3 border-t border-gray-100">
            <div class="text-xs text-gray-400">Showing page @currentPage of @totalPages</div>
            <div class="flex items-center gap-1">
                @if (currentPage > 1)
                {
                    <a href="/Students?currentPage=@(currentPage - 1)&search=@search"
                           class="w-7 h-7 flex items-center justify-center rounded border
                        border-gray-200 text-xs text-gray-500 hover:border-indigo-400">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                }
                @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                {
                    string pgClass = pg == currentPage
                      ? "bg-indigo-700 border-indigo-700 text-white"
                      : "border-gray-200 text-gray-500 hover:border-indigo-400";
                    <a href="/Students?currentPage=@pg&search=@search"
                           class="w-7 h-7 flex items-center justify-center rounded border text-xs @pgClass">
                        @pg
                    </a>
                }
                @if (currentPage < totalPages)
                {
                    <a href="/Students?currentPage=@(currentPage + 1)&search=@search"
                           class="w-7 h-7 flex items-center justify-center rounded border
                        border-gray-200 text-xs text-gray-500 hover:border-indigo-400">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
            </div>
        </div>
    }
</div>

<!-- Admin guidance bar -->
<div class="bg-white rounded-xl border border-gray-200 p-4 flex items-start gap-3">
  <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-content-center flex-shrink-0">
    <i class="bi bi-info-circle-fill text-indigo-600 mx-auto"></i>
  </div>
  <div>
    <div class="text-xs font-semibold text-indigo-700 mb-0.5">Administrative Guidance</div>
    <div class="text-xs text-gray-500">
      Remember to verify all new student registrations before assigning them to a class.
      Data exports are scheduled every Friday at 5:00 PM. If you encounter issues with student
      records, contact the IT support desk via the Help Center.
    </div>
  </div>
</div>

<!-- Delete confirm modal -->
<div id="deleteModal"
     class="hidden fixed inset-0 bg-black/40 flex items-center justify-content-center z-50">
  <div class="bg-white rounded-xl shadow-lg p-6 w-80">
    <div class="text-sm font-semibold text-gray-800 mb-1">Remove student?</div>
    <div class="text-xs text-gray-500 mb-4">
      You are about to remove <strong id="deleteName"></strong>.
      This will also delete their login account. This cannot be undone.
    </div>
    <form id="deleteForm" method="post">
      @Html.AntiForgeryToken()
      <div class="flex gap-2 justify-end">
        <button type="button" onclick="closeDelete()"
                class="text-xs px-4 py-2 border border-gray-200 rounded-lg hover:bg-gray-50">
          Cancel
        </button>
        <button type="submit"
                class="text-xs px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
          Yes, Remove
        </button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
function confirmDelete(id, name) {
  document.getElementById('deleteName').textContent = name;
  document.getElementById('deleteForm').action = '/Students/Delete/' + id;
  document.getElementById('deleteModal').classList.remove('hidden');
}
function closeDelete() {
  document.getElementById('deleteModal').classList.add('hidden');
}
</script>
}