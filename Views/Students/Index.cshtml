@model List<School_Management_System.Models.Student>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Student Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    int currentPage = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    int total = ViewBag.Total;
    string search = ViewBag.Search ?? "";
    int showingStart = total == 0 ? 0 : ((currentPage - 1) * 10 + 1);
    int showingEnd = Math.Min(currentPage * 10, total);
}

@section Styles {
<style>
  .students-shell {
    --primary: #000666;
    --primary-weak: #e0e0ff;
    --secondary: #1b6d24;
    --secondary-soft: #a0f399;
    --warning-strong: #d68500;
    --warning-soft: #ffddba;
    --error: #ba1a1a;
    --error-soft: #ffdad6;
    --surface: #ffffff;
    --surface-soft: #f3f3f3;
    --surface-muted: #e2e2e2;
    --outline-soft: #c6c5d4;
    --text-main: #1a1c1c;
    --text-dim: #454652;
    --text-faint: #767683;
    font-family: 'Inter', 'Segoe UI', sans-serif;
    color: var(--text-main);
  }

  .students-shell .section-title {
    font-size: 1.35rem;
    line-height: 1.2;
    font-weight: 800;
    color: var(--primary);
  }

  .students-shell .subtitle {
    font-size: .88rem;
    color: var(--text-dim);
  }

  .students-shell .btn-primary-solid {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    border: 0;
    border-radius: .25rem;
    padding: .62rem 1.35rem;
    background: var(--primary);
    color: #fff;
    font-size: .84rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity .2s ease;
  }

  .students-shell .btn-primary-solid:hover { opacity: .9; color: #fff; }

  .students-shell .success-banner {
    margin-bottom: 1rem;
    border: 1px solid #bbf7d0;
    background: #f0fdf4;
    color: #166534;
    border-radius: .25rem;
    padding: .58rem .8rem;
    font-size: .76rem;
    font-weight: 600;
  }

  .students-shell .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .students-shell .stat-card {
    background: var(--surface);
    border: 1px solid var(--outline-soft);
    border-radius: .12rem;
    box-shadow: 0 1px 2px rgba(0,0,0,.04);
    padding: .9rem;
    border-top-width: 3px;
    border-top-style: solid;
    display: flex;
    align-items: center;
    gap: .75rem;
  }

  .students-shell .stat-icon {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: .65rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    flex-shrink: 0;
  }

  .students-shell .stat-label {
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 700;
    color: #6b7280;
  }

  .students-shell .stat-value {
    font-size: 1.2rem;
    line-height: 1.1;
    font-weight: 800;
    margin-top: .15rem;
  }

  .students-shell .panel {
    background: var(--surface);
    border: 1px solid var(--outline-soft);
    border-radius: .12rem;
    box-shadow: 0 1px 2px rgba(0,0,0,.04);
    overflow: hidden;
  }

  .students-shell .toolbar {
    padding: .7rem .95rem;
    background: var(--surface-soft);
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .8rem;
    flex-wrap: wrap;
  }

  .students-shell .filter-form {
    display: flex;
    align-items: center;
    gap: .45rem;
    flex-wrap: wrap;
  }

  .students-shell .filter-box { position: relative; }

  .students-shell .filter-box i {
    position: absolute;
    left: .5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: .75rem;
    color: #9ca3af;
  }

  .students-shell .input,
  .students-shell .select {
    border: 1px solid #d1d5db;
    border-radius: .12rem;
    background: #fff;
    font-size: .76rem;
    color: #374151;
    height: 2rem;
  }

  .students-shell .input {
    width: 15rem;
    padding: .35rem .6rem .35rem 1.7rem;
  }

  .students-shell .select { padding: .35rem .55rem; min-width: 8.3rem; }

  .students-shell .mini-btn {
    border: 1px solid #d1d5db;
    background: #fff;
    border-radius: .12rem;
    padding: .3rem .62rem;
    font-size: .73rem;
    color: #374151;
    font-weight: 600;
  }

  .students-shell .mini-btn.primary {
    border-color: var(--primary);
    background: var(--primary);
    color: #fff;
  }

  .students-shell .toolbar-meta {
    display: flex;
    align-items: center;
    gap: .55rem;
    font-size: .76rem;
    color: #6b7280;
  }

  .students-shell .pager-arrows {
    display: inline-flex;
    border: 1px solid #d1d5db;
    border-radius: .12rem;
    overflow: hidden;
  }

  .students-shell .pager-arrows a,
  .students-shell .pager-arrows span {
    width: 1.75rem;
    height: 1.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #9ca3af;
    text-decoration: none;
    border-right: 1px solid #d1d5db;
    font-size: .8rem;
  }

  .students-shell .pager-arrows a:last-child,
  .students-shell .pager-arrows span:last-child { border-right: 0; }
  .students-shell .pager-arrows a:hover { background: #f3f4f6; color: #4b5563; }

  .students-shell table {
    width: 100%;
    border-collapse: collapse;
  }

  .students-shell thead th {
    background: #ececec;
    color: #4b5563;
    font-size: .71rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    padding: .78rem .95rem;
    text-align: left;
  }

  .students-shell tbody td {
    padding: .68rem .95rem;
    border-top: 1px solid #ededed;
    font-size: .82rem;
    color: #374151;
    vertical-align: middle;
  }

  .students-shell .student-photo {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid #e5e7eb;
  }

  .students-shell .student-name {
    font-size: .86rem;
    font-weight: 700;
    color: var(--primary);
    text-decoration: none;
  }

  .students-shell .student-name:hover { text-decoration: underline; }

  .students-shell .status-pill {
    font-size: .57rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .06em;
    border-radius: 999px;
    padding: .2rem .44rem;
    line-height: 1;
    display: inline-block;
    white-space: nowrap;
  }

  .students-shell .status-pill.continuing {
    background: var(--secondary-soft);
    color: #0f5d16;
  }

  .students-shell .status-pill.new {
    background: #ffd6a3;
    color: #7b4700;
  }

  .students-shell .actions {
    display: inline-flex;
    align-items: center;
    gap: .2rem;
  }

  .students-shell .action-link,
  .students-shell .action-btn {
    border: 0;
    background: transparent;
    color: #9ca3af;
    width: 1.55rem;
    height: 1.55rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: .14rem;
    text-decoration: none;
    font-size: .86rem;
  }

  .students-shell .action-link:hover,
  .students-shell .action-btn:hover { background: #f3f4f6; }
  .students-shell .action-link.view:hover { color: var(--primary); }
  .students-shell .action-link.edit:hover { color: #4338ca; }
  .students-shell .action-btn.delete:hover { color: var(--error); }

  .students-shell .empty-row {
    text-align: center;
    font-size: .8rem;
    color: #9ca3af;
    padding: 2rem 1rem !important;
  }

  .students-shell .panel-footer {
    padding: .72rem .95rem;
    border-top: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: .75rem;
    flex-wrap: wrap;
    font-size: .76rem;
    color: #6b7280;
  }

  .students-shell .page-list {
    display: inline-flex;
    align-items: center;
    gap: .18rem;
  }

  .students-shell .page-link {
    min-width: 1.75rem;
    height: 1.58rem;
    padding: 0 .38rem;
    border-radius: .12rem;
    text-align: center;
    line-height: 1.58rem;
    font-size: .72rem;
    text-decoration: none;
    color: #4b5563;
    border: 1px solid transparent;
  }

  .students-shell .page-link:hover { background: #f3f4f6; }
  .students-shell .page-link.active {
    border-color: #d1d5db;
    background: #f3f4f6;
    color: #1f2937;
    font-weight: 700;
  }

  .students-shell .admin-note {
    margin-top: 1rem;
    background: #f6f6f6;
    border: 1px solid var(--outline-soft);
    border-radius: .34rem;
    padding: 1rem;
    display: flex;
    align-items: flex-start;
    gap: .7rem;
  }

  .students-shell .admin-note-icon {
    color: var(--primary);
    font-size: 1.2rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: .1rem;
  }

  .students-shell .admin-note-title {
    color: var(--primary);
    font-size: .86rem;
    font-weight: 700;
    margin-bottom: .12rem;
  }

  .students-shell .admin-note-text {
    font-size: .82rem;
    color: #4b5563;
    line-height: 1.45;
    max-width: 56rem;
  }

  .students-shell .delete-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .36);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 80;
  }
  .students-shell .delete-modal-backdrop.is-open { display: flex; }

  .students-shell .delete-modal {
    width: 22rem;
    border-radius: .35rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    box-shadow: 0 20px 45px rgba(0, 0, 0, .22);
    padding: 1rem;
  }

  .students-shell .delete-modal-title {
    font-size: .98rem;
    font-weight: 700;
    color: #1f2937;
  }

  .students-shell .delete-modal-copy {
    margin-top: .35rem;
    font-size: .79rem;
    color: #4b5563;
    line-height: 1.45;
  }

  .students-shell .delete-modal-actions {
    margin-top: .85rem;
    display: flex;
    justify-content: flex-end;
    gap: .45rem;
  }

  .students-shell .ghost-btn {
    border: 1px solid #d1d5db;
    background: #fff;
    color: #374151;
    border-radius: .2rem;
    padding: .45rem .82rem;
    font-size: .76rem;
    font-weight: 600;
  }

  .students-shell .danger-btn {
    border: 1px solid #b91c1c;
    background: #dc2626;
    color: #fff;
    border-radius: .2rem;
    padding: .45rem .82rem;
    font-size: .76rem;
    font-weight: 700;
  }

  @@media (max-width: 1100px) {
    .students-shell .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @@media (max-width: 760px) {
    .students-shell .stats-grid { grid-template-columns: 1fr; }
    .students-shell .input { width: 100%; }
  }
</style>
}

<div class="students-shell">
  <div class="flex justify-between items-end mb-4 gap-3 flex-wrap">
    <div>
      <h2 class="section-title">Student Management</h2>
      <p class="subtitle">Manage registrations, academic tracks, and student records.</p>
    </div>
    <a href="/Students/Create" class="btn-primary-solid">
      <i class="bi bi-plus-lg"></i>
      Add New Student
    </a>
  </div>

  @if (TempData["Success"] != null)
  {
    <div class="success-banner">
      <i class="bi bi-check-circle-fill me-1"></i>@TempData["Success"]
    </div>
  }

  <div class="stats-grid">
    <div class="stat-card" style="border-top-color:var(--primary)">
      <div class="stat-icon" style="background:var(--primary-weak);color:var(--primary)">
        <i class="bi bi-people-fill"></i>
      </div>
      <div>
        <p class="stat-label">Total Students</p>
        <h3 class="stat-value" style="color:var(--primary)">@ViewBag.TotalStudents.ToString("N0")</h3>
      </div>
    </div>
    <div class="stat-card" style="border-top-color:var(--secondary)">
      <div class="stat-icon" style="background:var(--secondary-soft);color:var(--secondary)">
        <i class="bi bi-person-plus-fill"></i>
      </div>
      <div>
        <p class="stat-label">New Enrolments</p>
        <h3 class="stat-value" style="color:var(--secondary)">@ViewBag.NewEnrolments</h3>
      </div>
    </div>
    <div class="stat-card" style="border-top-color:var(--warning-strong)">
      <div class="stat-icon" style="background:var(--warning-soft);color:var(--warning-strong)">
        <i class="bi bi-exclamation-triangle-fill"></i>
      </div>
      <div>
        <p class="stat-label">Attendance Alerts</p>
        <h3 class="stat-value" style="color:var(--warning-strong)">@ViewBag.AttendanceAlerts</h3>
      </div>
    </div>
    <div class="stat-card" style="border-top-color:var(--error)">
      <div class="stat-icon" style="background:var(--error-soft);color:var(--error)">
        <i class="bi bi-cash-stack"></i>
      </div>
      <div>
        <p class="stat-label">Unpaid Fees</p>
        <h3 class="stat-value" style="color:var(--error)">@ViewBag.UnpaidFees</h3>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="toolbar">
      <form method="get" action="/Students" class="filter-form">
        <div class="filter-box">
          <i class="bi bi-funnel"></i>
          <input name="search" value="@search" placeholder="Filter by name..." class="input" />
        </div>
        <select name="classId" class="select">
          <option value="">All Classes</option>
          @foreach (SelectListItem item in ViewBag.Classes)
          {
            if (item.Selected)
            {
              <option value="@item.Value" selected>@item.Text</option>
            }
            else
            {
              <option value="@item.Value">@item.Text</option>
            }
          }
        </select>
        <button type="submit" class="mini-btn primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(search))
        {
          <a href="/Students" class="mini-btn">Clear</a>
        }
      </form>
      <div class="toolbar-meta">
        <span>Showing @showingStart-@showingEnd of @total.ToString("N0")</span>
        <div class="pager-arrows">
          @if (currentPage > 1)
          {
            <a href="/Students?currentPage=@(currentPage - 1)&search=@search&classId=@ViewBag.ClassId" aria-label="Previous">
              <i class="bi bi-chevron-left"></i>
            </a>
          }
          else
          {
            <span><i class="bi bi-chevron-left"></i></span>
          }
          @if (currentPage < totalPages)
          {
            <a href="/Students?currentPage=@(currentPage + 1)&search=@search&classId=@ViewBag.ClassId" aria-label="Next">
              <i class="bi bi-chevron-right"></i>
            </a>
          }
          else
          {
            <span><i class="bi bi-chevron-right"></i></span>
          }
        </div>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Photo</th>
          <th>Full Name</th>
          <th>Class</th>
          <th>Gender</th>
          <th>Status</th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
      @if (!Model.Any())
      {
        <tr>
          <td colspan="6" class="empty-row">
            No students found.
            <a href="/Students/Create" style="color:var(--primary);text-decoration:underline;">Add one now</a>.
          </td>
        </tr>
      }
      @foreach (var s in Model)
      {
        <tr>
          <td>
            <img src="@s.PhotoPath"
                 onerror="this.src='/images/default-avatar.png'"
                 class="student-photo"
                 alt="@s.FullName" />
          </td>
          <td>
            <a href="/Students/Details/@s.Id" class="student-name">@s.FullName</a>
          </td>
          <td>@(s.Class?.Name ?? "—")</td>
          <td>@s.Gender</td>
          <td>
            <span class="status-pill @(s.Status == "Continuing" ? "continuing" : "new")">
              @s.Status.ToUpper()
            </span>
          </td>
          <td style="text-align:right">
            <div class="actions">
              <a href="/Students/Details/@s.Id" class="action-link view" title="View">
                <i class="bi bi-eye"></i>
              </a>
              <a href="/Students/Edit/@s.Id" class="action-link edit" title="Edit">
                <i class="bi bi-pencil"></i>
              </a>
              <button type="button"
                      onclick="confirmDelete(@s.Id, '@s.FullName'.replace(/'/g, '\\&#39;'))"
                      class="action-btn delete"
                      title="Delete">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </td>
        </tr>
      }
      </tbody>
    </table>

    <div class="panel-footer">
      <span>Showing page @currentPage of @Math.Max(totalPages, 1)</span>
      @if (totalPages > 1)
      {
        <div class="page-list">
          @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
          {
            <a href="/Students?currentPage=@pg&search=@search&classId=@ViewBag.ClassId"
               class="page-link @(pg == currentPage ? "active" : "")">@pg</a>
          }
          @if (currentPage + 2 < totalPages)
          {
            <span class="page-link" style="pointer-events:none;">...</span>
            <a href="/Students?currentPage=@totalPages&search=@search&classId=@ViewBag.ClassId"
               class="page-link">@totalPages</a>
          }
        </div>
      }
    </div>
  </div>

  <div class="admin-note">
    <div class="admin-note-icon">
      <i class="bi bi-info-circle-fill"></i>
    </div>
    <div>
      <h4 class="admin-note-title">Administrative Guidance</h4>
      <p class="admin-note-text">
        Remember to verify all new student registrations before assigning them to a class. Data exports are
        scheduled every Friday at 5:00 PM. If you encounter issues with student records, contact the IT support
        desk via the Help Center.
      </p>
    </div>
  </div>

  <div id="deleteModal" class="delete-modal-backdrop">
    <div class="delete-modal">
      <div class="delete-modal-title">Remove student?</div>
      <div class="delete-modal-copy">
        You are about to remove <strong id="deleteName"></strong>.
        This will also delete their login account. This cannot be undone.
      </div>
      <form id="deleteForm" method="post">
        @Html.AntiForgeryToken()
        <div class="delete-modal-actions">
          <button type="button" onclick="closeDelete()" class="ghost-btn">Cancel</button>
          <button type="submit" class="danger-btn">Yes, Remove</button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
function confirmDelete(id, name) {
  document.getElementById('deleteName').textContent = name;
  document.getElementById('deleteForm').action = '/Students/Delete/' + id;
  document.getElementById('deleteModal').classList.add('is-open');
}

function closeDelete() {
  document.getElementById('deleteModal').classList.remove('is-open');
}
</script>
}
