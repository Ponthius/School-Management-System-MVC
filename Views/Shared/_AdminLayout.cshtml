@{
    var username = Context.Session.GetString("Username") ?? "admin";
    var role = Context.Session.GetString("UserRole") ?? "Admin";
    var initials = username.Length >= 2 ? username[..2].ToUpper() : username.ToUpper();
    var current = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    var searchPlaceholder = string.Equals(current, "ClassSubjects", StringComparison.OrdinalIgnoreCase)
        ? "Search class, subject or teacher..."
        : "Search students, teachers, classes...";

    string Active(string controller)
    {
        return string.Equals(current, controller, StringComparison.OrdinalIgnoreCase)
            ? "sms-nav-link active"
            : "sms-nav-link";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] — Brait Inc SMS</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #1a237e;
            --primary-soft: #283593;
            --primary-light: #eef0ff;
            --green: #1b6d24;
            --green-soft: #e8f8ea;
            --amber: #b76400;
            --amber-soft: #fff4df;
            --red: #ba1a1a;
            --red-soft: #ffefed;
            --text: #1a1c1c;
            --muted: #767683;
            --border: #dfe2ec;
            --surface: #f6f7fb;
            --white: #ffffff;
            --sidebar-width: 200px;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            font-family: Inter, Arial, sans-serif;
            background: var(--surface);
            color: var(--text);
        }

        a {
            text-decoration: none;
        }

        button,
        input {
            font-family: inherit;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 24;
            line-height: 1;
        }

        .sms-shell {
            min-height: 100vh;
        }

        /* =========================
           SIDEBAR
        ========================= */

        .sms-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            width: var(--sidebar-width);
            background: var(--primary);
            color: white;
            display: flex;
            flex-direction: column;
            z-index: 50;
            overflow: hidden;
        }

        .sms-brand {
            padding: 16px 16px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .sms-brand-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255, 255, 255, .15);
            color: white;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .sms-brand-icon .material-symbols-outlined {
            font-size: 18px;
        }

        .sms-brand-title {
            font-size: 13px;
            line-height: 1.1;
            font-weight: 800;
            letter-spacing: 0;
            color: white;
            white-space: nowrap;
        }

        .sms-brand-subtitle {
            margin-top: 3px;
            font-size: 8px;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: #c7ccff;
            font-weight: 700;
            white-space: nowrap;
        }

        .sms-role-pill {
            margin: 0 16px 12px;
            padding: 6px 10px;
            border-radius: 4px;
            background: rgba(255, 255, 255, .10);
            color: #e7e9ff;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .14em;
            display: flex;
            gap: 8px;
            align-items: center;
            flex-shrink: 0;
        }

        .sms-role-dot {
            width: 7px;
            height: 7px;
            background: #35d66b;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .sms-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 6px 0;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,.45) transparent;
        }

        .sms-nav::-webkit-scrollbar {
            width: 5px;
        }

        .sms-nav::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.35);
            border-radius: 20px;
        }

        .sms-nav-section {
            padding: 13px 16px 6px;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: .14em;
            color: rgba(255,255,255,.42);
            text-transform: uppercase;
        }

        .sms-nav-link {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 10px 16px;
            color: rgba(255,255,255,.72);
            font-size: 12px;
            font-weight: 500;
            border-left: 4px solid transparent;
            transition: .18s ease;
            min-height: 39px;
        }

        .sms-nav-link:hover {
            background: rgba(255,255,255,.08);
            color: white;
        }

        .sms-nav-link.active {
            background: var(--primary-soft);
            color: white;
            border-left-color: #c7ccff;
            font-weight: 800;
        }

        .sms-nav-link .material-symbols-outlined {
            font-size: 17px;
            flex-shrink: 0;
        }

        .sms-nav-link span:not(.material-symbols-outlined) {
            font-size: 12px;
            line-height: 1.2;
            white-space: nowrap;
        }

        .sms-sidebar-footer {
            border-top: 1px solid rgba(255,255,255,.12);
            padding: 10px 0;
            flex-shrink: 0;
            background: var(--primary);
        }

        .sms-user-mini {
            margin: 0 16px 8px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sms-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #eef0ff;
            color: var(--primary);
            font-size: 10px;
            font-weight: 900;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .sms-user-name {
            font-size: 12px;
            font-weight: 800;
            color: white;
            line-height: 1.1;
        }

        .sms-user-role {
            margin-top: 2px;
            font-size: 10px;
            color: rgba(255,255,255,.62);
        }

        /* =========================
           MAIN AREA
        ========================= */

        .sms-main {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .sms-topbar {
            height: 54px;
            background: white;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .sms-search {
            width: min(280px, 100%);
            position: relative;
        }

        .sms-search .material-symbols-outlined {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #8b8fa3;
            font-size: 16px;
            pointer-events: none;
        }

        .sms-search input {
            width: 100%;
            border: 1px solid var(--border);
            background: #f8f9fc;
            border-radius: 6px;
            padding: 8px 12px 8px 32px;
            font-size: 12px;
            outline: none;
        }

        .sms-search input:focus {
            border-color: var(--primary);
            background: white;
        }

        .sms-top-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sms-icon-btn {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: white;
            color: #596070;
            display: grid;
            place-items: center;
            cursor: pointer;
        }

        .sms-icon-btn .material-symbols-outlined {
            font-size: 17px;
        }

        .sms-icon-btn:hover {
            background: #f7f8fc;
        }

        .sms-top-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-left: 10px;
            border-left: 1px solid var(--border);
        }

        .sms-top-user-name {
            font-size: 12px;
            font-weight: 800;
            color: var(--primary);
            text-align: right;
            line-height: 1.1;
        }

        .sms-top-user-role {
            margin-top: 2px;
            font-size: 10px;
            color: var(--muted);
            text-align: right;
        }

        .sms-top-user .sms-avatar {
            background: var(--primary);
            color: white;
        }

        .sms-content {
            padding: 20px 24px;
        }

        /* =========================
           RESPONSIVE
        ========================= */

        @@media (max-width: 900px) {
            :root {
                --sidebar-width: 82px;
            }

            .sms-brand {
                justify-content: center;
                padding-left: 0;
                padding-right: 0;
            }

            .sms-brand div:last-child,
            .sms-role-pill,
            .sms-nav-section,
            .sms-nav-link span:not(.material-symbols-outlined),
            .sms-user-mini div:last-child {
                display: none;
            }

            .sms-nav-link {
                justify-content: center;
                padding-left: 0;
                padding-right: 0;
                border-left-width: 3px;
            }

            .sms-content {
                padding: 18px;
            }
        }

        @@media (max-width: 650px) {
            .sms-topbar {
                padding: 0 16px;
            }

            .sms-search {
                width: 210px;
            }

            .sms-top-user {
                display: none;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="sms-shell">
        <aside class="sms-sidebar">
            <div class="sms-brand">
                <div class="sms-brand-icon">
                    <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">school</span>
                </div>

                <div>
                    <div class="sms-brand-title">Brait Inc SMS</div>
                    <div class="sms-brand-subtitle">Administrative Portal</div>
                </div>
            </div>

            <div class="sms-role-pill">
                <span class="sms-role-dot"></span>
                <span>@role Role</span>
            </div>

            <nav class="sms-nav">
                <div class="sms-nav-section">Main</div>

                <a class="@Active("Dashboard")" href="@Url.Action("Admin", "Dashboard")">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Dashboard</span>
                </a>

                <div class="sms-nav-section">Management</div>

                <a class="@Active("Students")" href="@Url.Action("Index", "Students")">
                    <span class="material-symbols-outlined">groups</span>
                    <span>Students</span>
                </a>

                <a class="@Active("Teachers")" href="@Url.Action("Index", "Teachers")">
                    <span class="material-symbols-outlined">badge</span>
                    <span>Teachers</span>
                </a>

                <a class="@Active("ClassSubjects")" href="@Url.Action("Index", "ClassSubjects")">
                    <span class="material-symbols-outlined">fact_check</span>
                    <span>Classes &amp; Subjects</span>
                </a>

                <div class="sms-nav-section">Academic</div>

                <a class="@Active("Attendance")" href="@Url.Action("Index", "Attendance")">
                    <span class="material-symbols-outlined">event_available</span>
                    <span>Attendance</span>
                </a>

                <a class="@Active("Exams")" href="@Url.Action("Index", "Exams")">
                    <span class="material-symbols-outlined">assignment</span>
                    <span>Exams</span>
                </a>

                <a class="@Active("Results")" href="@Url.Action("Index", "Results")">
                    <span class="material-symbols-outlined">monitoring</span>
                    <span>Results</span>
                </a>

                <div class="sms-nav-section">Finance</div>

                <a class="@Active("Payments")" href="@Url.Action("Index", "Payments")">
                    <span class="material-symbols-outlined">account_balance_wallet</span>
                    <span>Payments</span>
                </a>

                <div class="sms-nav-section">System</div>

                <a class="@Active("Help")" href="#">
                    <span class="material-symbols-outlined">contact_support</span>
                    <span>Help Center</span>
                </a>

                <a class="@Active("Settings")" href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Settings</span>
                </a>
            </nav>

            <div class="sms-sidebar-footer">
                <div class="sms-user-mini">
                    <div class="sms-avatar">@initials</div>

                    <div>
                        <div class="sms-user-name">@username</div>
                        <div class="sms-user-role">Administrator</div>
                    </div>
                </div>

                <a class="sms-nav-link" href="@Url.Action("Logout", "Account")">
                    <span class="material-symbols-outlined">logout</span>
                    <span>Sign Out</span>
                </a>
            </div>
        </aside>

        <main class="sms-main">
            <header class="sms-topbar">
                <form class="sms-search" method="get">
                    <span class="material-symbols-outlined">search</span>
                    <input name="search" value="@Context.Request.Query["search"]" placeholder="@searchPlaceholder" />
                </form>

                <div class="sms-top-actions">
                    <button class="sms-icon-btn" type="button">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>

                    <button class="sms-icon-btn" type="button">
                        <span class="material-symbols-outlined">help_outline</span>
                    </button>

                    <button class="sms-icon-btn" type="button">
                        <span class="material-symbols-outlined">settings</span>
                    </button>

                    <div class="sms-top-user">
                        <div>
                            <div class="sms-top-user-name">@username</div>
                            <div class="sms-top-user-role">Administrator</div>
                        </div>

                        <div class="sms-avatar">@initials</div>
                    </div>
                </div>
            </header>

            <section class="sms-content">
                @RenderBody()
            </section>
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>