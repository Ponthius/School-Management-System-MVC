@{
    var username = Context.Session.GetString("Username") ?? "Admin";
    var initials = username.Length >= 2 ? username[..2].ToUpper() : username.ToUpper();
    var current  = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>@ViewData["Title"] — EduFlow SMS</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"/>
<style>
  body { font-family: 'Segoe UI', sans-serif; }
  .sidebar { width: 200px; min-height: 100vh; background: #1e2a78;
             position: fixed; top:0; left:0; bottom:0; z-index:200;
             display:flex; flex-direction:column; }
  .main    { margin-left: 200px; min-height: 100vh; background: #f4f6fb; }
  .nav-link-item { display:flex; align-items:center; gap:9px;
                   padding:.5rem 1rem; color:rgba(255,255,255,.65);
                   text-decoration:none; font-size:.82rem;
                   transition:background .15s,color .15s; }
  .nav-link-item:hover { background:rgba(255,255,255,.1); color:#fff; }
  .nav-link-item.active { background:rgba(255,255,255,.12); color:#fff;
                          border-left:3px solid #818cf8; }
  .nav-link-item i { width:18px; text-align:center; }
  .status-pill { font-size:.68rem; font-weight:600; padding:.2rem .55rem;
                 border-radius:999px; }
  .s-continuing { background:#dcfce7; color:#15803d; }
  .s-new        { background:#fef9c3; color:#854d0e; }
</style>
@RenderSection("Styles", required: false)
</head>
<body class="flex">

<!-- Sidebar -->
<aside class="sidebar">
  <div style="padding:1rem;border-bottom:1px solid rgba(255,255,255,.1)">
    <div class="flex items-center gap-2">
      <div style="width:32px;height:32px;background:rgba(255,255,255,.15);border-radius:8px;
                  display:flex;align-items:center;justify-content:center;color:#fff;font-size:.95rem">
        <i class="bi bi-mortarboard-fill"></i>
      </div>
      <div>
        <div style="color:#fff;font-weight:700;font-size:.92rem">EduFlow SMS</div>
        <div style="color:rgba(255,255,255,.4);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase">
          Administrative Portal
        </div>
      </div>
    </div>
    <div style="margin-top:.6rem;background:rgba(255,255,255,.08);border-radius:4px;
                padding:.28rem .7rem;display:inline-block;font-size:.62rem;
                font-weight:600;color:#a5b4fc;letter-spacing:.06em;text-transform:uppercase">
      <span style="width:7px;height:7px;background:#22c55e;border-radius:50%;
                   display:inline-block;margin-right:5px"></span>Super Admin
    </div>
  </div>

  <nav style="flex:1;padding:.5rem 0;overflow-y:auto">
    <a href="/Dashboard/Admin"
       class="nav-link-item @(current=="Dashboard"?"active":"")">
      <i class="bi bi-grid-1x2-fill"></i> Dashboard
    </a>
    <a href="/Students"
       class="nav-link-item @(current=="Students"?"active":"")">
      <i class="bi bi-people-fill"></i> Students
    </a>
    <a href="/Teachers"
       class="nav-link-item @(current=="Teachers"?"active":"")">
      <i class="bi bi-person-badge-fill"></i> Teachers
    </a>
    <a href="/Classes"
       class="nav-link-item @(current=="Classes"?"active":"")">
      <i class="bi bi-building"></i> Classes
    </a>
    <a href="/Exams"
       class="nav-link-item @(current=="Exams"?"active":"")">
      <i class="bi bi-journal-text"></i> Exams
    </a>
    <a href="/Payments"
       class="nav-link-item @(current=="Payments"?"active":"")">
      <i class="bi bi-cash-coin"></i> Payments
    </a>
    <div style="margin-top:auto"></div>
    <a href="#" class="nav-link-item" style="margin-top:1rem">
      <i class="bi bi-question-circle"></i> Help Center
    </a>
    <a href="#" class="nav-link-item">
      <i class="bi bi-gear"></i> Settings
    </a>
  </nav>

  <div style="padding:.8rem 1rem;border-top:1px solid rgba(255,255,255,.1)">
    <a href="/Account/Logout"
       style="display:flex;align-items:center;gap:8px;color:rgba(255,255,255,.5);
              font-size:.78rem;text-decoration:none">
      <i class="bi bi-box-arrow-left"></i> Logout
    </a>
  </div>
</aside>

<!-- Main -->
<div class="main flex-1 flex flex-col">

  <!-- Topbar -->
  <div class="bg-white border-b border-gray-200 px-6 py-2 flex items-center gap-3 sticky top-0 z-10">
    <div class="relative flex-1 max-w-xs">
      <i class="bi bi-search absolute left-2 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
      <input type="text" placeholder="Search students, teachers, or files..."
             class="w-full border border-gray-200 rounded-md pl-7 pr-3 py-1.5
                    text-xs bg-gray-50 outline-none focus:border-indigo-400"/>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <button class="w-8 h-8 rounded-md border border-gray-200 flex items-center
                     justify-content-center text-gray-500 relative">
        <i class="bi bi-bell text-sm mx-auto"></i>
        <span class="absolute top-1 right-1 w-1.5 h-1.5 bg-red-500 rounded-full"></span>
      </button>
      <button class="w-8 h-8 rounded-md border border-gray-200 flex items-center
                     justify-content-center text-gray-500">
        <i class="bi bi-gear text-sm mx-auto"></i>
      </button>
      <div class="flex items-center gap-2 text-sm">
        <div class="text-right">
          <div class="font-semibold text-gray-800 text-xs">Administrator</div>
        </div>
        <div style="width:30px;height:30px;border-radius:50%;background:#1e2a78;color:#fff;
                    display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700">
          @initials
        </div>
      </div>
    </div>
  </div>

  <!-- Page body -->
  <div class="flex-1 p-5">
    @RenderBody()
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>