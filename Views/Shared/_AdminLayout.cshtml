@{
    var username = Context.Session.GetString("Username") ?? "Admin";
    var initials = username.Length >= 2 ? username[..2].ToUpper() : username.ToUpper();
    var current  = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>@ViewData["Title"] — School Management System</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"/>
<style>
  body { font-family: 'Segoe UI', sans-serif; }

  /* ── Sidebar ── */
  .sidebar {
    width: 210px;
    min-height: 100vh;
    background: #1e2a78;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 200;
    display: flex;
    flex-direction: column;
  }

  /* ── Main content area ── */
  .main { margin-left: 210px; min-height: 100vh; background: #f4f6fb; }

  /* ── Nav links ── */
  .nav-link-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: .52rem 1rem;
    color: rgba(255,255,255,.65);
    text-decoration: none;
    font-size: .82rem;
    transition: background .15s, color .15s;
    border-left: 3px solid transparent;
  }
  .nav-link-item:hover {
    background: rgba(255,255,255,.08);
    color: #fff;
  }
  .nav-link-item.active {
    background: rgba(255,255,255,.12);
    color: #fff;
    border-left: 3px solid #818cf8;
  }
  .nav-link-item i {
    width: 18px;
    text-align: center;
    font-size: .95rem;
  }

  /* ── Nav section label ── */
  .nav-section {
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.3);
    padding: .8rem 1rem .2rem;
  }

  /* ── Status pills (used in student tables) ── */
  .status-pill {
    font-size: .68rem;
    font-weight: 600;
    padding: .2rem .55rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .s-continuing { background: #dcfce7; color: #15803d; }
  .s-new        { background: #fef9c3; color: #854d0e; }
</style>
@RenderSection("Styles", required: false)
</head>
<body class="flex">

<!-- ══════════════ SIDEBAR ══════════════ -->
<aside class="sidebar">

  <!-- Brand -->
  <div style="padding:1rem 1rem .8rem;border-bottom:1px solid rgba(255,255,255,.1)">
    <div class="flex items-center gap-2">
      <div style="width:34px;height:34px;background:rgba(255,255,255,.15);border-radius:8px;
                  display:flex;align-items:center;justify-content:center;
                  color:#fff;font-size:1rem;flex-shrink:0">
        <i class="bi bi-mortarboard-fill"></i>
      </div>
      <div>
        <div style="color:#fff;font-weight:700;font-size:.88rem;line-height:1.2">SMS</div>
        <div style="color:rgba(255,255,255,.4);font-size:.58rem;
                    letter-spacing:.08em;text-transform:uppercase">
          Administrative Portal
        </div>
      </div>
    </div>
    <!-- Role badge -->
    <div style="margin-top:.65rem;background:rgba(255,255,255,.08);border-radius:4px;
                padding:.28rem .75rem;display:inline-flex;align-items:center;gap:6px;
                font-size:.62rem;font-weight:600;color:#a5b4fc;
                letter-spacing:.06em;text-transform:uppercase">
      <span style="width:7px;height:7px;background:#22c55e;
                   border-radius:50%;display:inline-block;flex-shrink:0"></span>
      Admin Role
    </div>
  </div>

  <!-- Navigation -->
  <nav style="flex:1;padding:.4rem 0;overflow-y:auto">

    <div class="nav-section">Main</div>
    <a href="/Dashboard/Admin"
       class="nav-link-item @(current == "Dashboard" ? "active" : "")">
      <i class="bi bi-grid-1x2-fill"></i> Dashboard
    </a>

    <div class="nav-section">Management</div>
    <a href="/Students/"
       class="nav-link-item @(current == "Students" ? "active" : "")">
      <i class="bi bi-people-fill"></i> Students
    </a>
    <a href="/Teachers"
       class="nav-link-item @(current == "Teachers" ? "active" : "")">
      <i class="bi bi-person-badge-fill"></i> Teachers
    </a>
    <a href="/Classes"
       class="nav-link-item @(current == "Classes" ? "active" : "")">
      <i class="bi bi-building"></i> Classes
    </a>
    <a href="/Subjects"
       class="nav-link-item @(current == "Subjects" ? "active" : "")">
      <i class="bi bi-book"></i> Subjects
    </a>

    <div class="nav-section">Academic</div>
    <a href="/Attendance"
       class="nav-link-item @(current == "Attendance" ? "active" : "")">
      <i class="bi bi-calendar-check"></i> Attendance
    </a>
    <a href="/Exams"
       class="nav-link-item @(current == "Exams" ? "active" : "")">
      <i class="bi bi-journal-text"></i> Exams
    </a>
    <a href="/Results"
       class="nav-link-item @(current == "Results" ? "active" : "")">
      <i class="bi bi-bar-chart-line"></i> Results
    </a>

    <div class="nav-section">Finance</div>
    <a href="/Payments"
       class="nav-link-item @(current == "Payments" ? "active" : "")">
      <i class="bi bi-cash-coin"></i> Payments
    </a>

    <div class="nav-section">System</div>
    <a href="#"
       class="nav-link-item @(current == "Help" ? "active" : "")">
      <i class="bi bi-question-circle"></i> Help Center
    </a>
    <a href="#"
       class="nav-link-item @(current == "Settings" ? "active" : "")">
      <i class="bi bi-gear"></i> Settings
    </a>

  </nav>

  <!-- Logout footer -->
  <div style="padding:.9rem 1rem;border-top:1px solid rgba(255,255,255,.1)">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:.6rem">
      <div style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.15);
                  display:flex;align-items:center;justify-content:center;
                  color:#fff;font-size:.68rem;font-weight:700;flex-shrink:0">
        @initials
      </div>
      <div>
        <div style="color:#fff;font-size:.75rem;font-weight:600;line-height:1.2">@username</div>
        <div style="color:rgba(255,255,255,.4);font-size:.65rem">Administrator</div>
      </div>
    </div>
    <a href="/Account/Logout"
       style="display:flex;align-items:center;gap:7px;color:rgba(255,255,255,.45);
              font-size:.76rem;text-decoration:none;transition:color .15s"
       onmouseover="this.style.color='#fff'"
       onmouseout="this.style.color='rgba(255,255,255,.45)'">
      <i class="bi bi-box-arrow-left"></i> Sign Out
    </a>
  </div>

</aside>

<!-- ══════════════ MAIN ══════════════ -->
<div class="main flex-1 flex flex-col">

  <!-- Topbar -->
  <div class="bg-white border-b border-gray-200 px-6 py-2 flex items-center gap-3 sticky top-0 z-10">

    <!-- Search -->
    <div class="relative flex-1 max-w-xs">
      <i class="bi bi-search absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
      <input type="text"
             placeholder="Search students, teachers, or files..."
             class="w-full border border-gray-200 rounded-md pl-7 pr-3 py-1.5
                    text-xs bg-gray-50 outline-none focus:border-indigo-400
                    focus:bg-white transition"/>
    </div>

    <!-- Right side -->
    <div class="ml-auto flex items-center gap-2">

      <!-- Bell -->
      <button class="w-8 h-8 rounded-md border border-gray-200 bg-white
                     flex items-center justify-center text-gray-500
                     hover:border-indigo-300 transition relative">
        <i class="bi bi-bell text-sm"></i>
        <span class="absolute top-1.5 right-1.5 w-1.5 h-1.5 bg-red-500 rounded-full"></span>
      </button>

      <!-- Gear -->
      <button class="w-8 h-8 rounded-md border border-gray-200 bg-white
                     flex items-center justify-center text-gray-500
                     hover:border-indigo-300 transition">
        <i class="bi bi-gear text-sm"></i>
      </button>

      <!-- User chip -->
      <div class="flex items-center gap-2 pl-2 border-l border-gray-200">
        <div class="text-right hidden sm:block">
          <div class="font-semibold text-gray-800 text-xs leading-tight">@username</div>
          <div class="text-gray-400 text-xs">Administrator</div>
        </div>
        <div style="width:30px;height:30px;border-radius:50%;background:#1e2a78;
                    color:#fff;display:flex;align-items:center;justify-content:center;
                    font-size:.68rem;font-weight:700;flex-shrink:0">
          @initials
        </div>
      </div>

    </div>
  </div>

  <!-- Page body -->
  <div class="flex-1 p-5">
    @RenderBody()
  </div>

</div><!-- /main -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>