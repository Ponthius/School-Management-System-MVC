@model School_Management_System.Models.ViewModels.AttendanceDashboardViewModel

@{
    ViewData["Title"] = "Attendance";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var statusOptions = new[] { "Present", "Absent", "Late", "Excused" };
}

@section Styles {
<style>
    .att-page {
        --primary: #000666;
        --primary-soft: #eef0ff;
        --green: #1b6d24;
        --green-soft: #e8f8ea;
        --amber: #b76400;
        --amber-soft: #fff4df;
        --red: #ba1a1a;
        --red-soft: #ffefed;
        --border: #dfe2ec;
        --muted: #697083;
        color: #172033;
    }

    .att-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .att-title {
        margin: 0;
        color: var(--primary);
        font-size: 1.45rem;
        font-weight: 900;
        letter-spacing: -.02em;
    }

    .att-sub {
        margin: .35rem 0 0;
        color: var(--muted);
        font-size: .82rem;
    }

    .att-filter {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: .45rem;
        padding: .8rem;
        display: grid;
        grid-template-columns: 1.2fr .8fr 1.2fr .8fr auto;
        gap: .6rem;
        margin-bottom: 1rem;
        align-items: end;
    }

    .att-field label {
        display: block;
        color: #50586b;
        font-size: .66rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: .3rem;
    }

    .att-input,
    .att-select {
        width: 100%;
        height: 2.35rem;
        border: 1px solid #cfd5e3;
        border-radius: .25rem;
        background: #fff;
        color: #111827;
        font-size: .8rem;
        padding: .4rem .6rem;
        outline: none;
    }

    .att-input:focus,
    .att-select:focus {
        border-color: var(--primary);
    }

    .att-btn {
        min-height: 2.35rem;
        border: 0;
        border-radius: .25rem;
        padding: .45rem .8rem;
        font-size: .78rem;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        cursor: pointer;
        text-decoration: none;
    }

    .att-btn.primary {
        background: var(--primary);
        color: #fff;
    }

    .att-btn.ghost {
        background: #fff;
        color: var(--primary);
        border: 1px solid var(--border);
    }

    .att-alert {
        border-radius: .3rem;
        padding: .65rem .8rem;
        margin-bottom: .8rem;
        font-size: .78rem;
        font-weight: 800;
    }

    .att-alert.ok { background: var(--green-soft); color: #155d1e; border: 1px solid #bbe8c1; }
    .att-alert.err { background: var(--red-soft); color: var(--red); border: 1px solid #ffd0cb; }

    .att-stats {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: .85rem;
        margin-bottom: 1rem;
    }

    .att-stat {
        background: #fff;
        border: 1px solid var(--border);
        border-top: 4px solid var(--primary);
        border-radius: .4rem;
        padding: .9rem;
        display: flex;
        align-items: center;
        gap: .7rem;
    }

    .att-stat-icon {
        width: 2.2rem;
        height: 2.2rem;
        border-radius: .45rem;
        display: grid;
        place-items: center;
        background: var(--primary-soft);
        color: var(--primary);
        flex-shrink: 0;
    }

    .att-stat-label {
        color: var(--muted);
        font-size: .62rem;
        text-transform: uppercase;
        font-weight: 900;
        letter-spacing: .08em;
    }

    .att-stat-value {
        margin-top: .12rem;
        color: var(--primary);
        font-size: 1.25rem;
        font-weight: 900;
        line-height: 1;
    }

    .att-panel {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: .45rem;
        overflow: hidden;
    }

    .att-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: .85rem 1rem;
        background: #fbfcff;
        border-bottom: 1px solid var(--border);
    }

    .att-panel-title {
        margin: 0;
        color: var(--primary);
        font-size: .98rem;
        font-weight: 900;
    }

    .att-table {
        width: 100%;
        border-collapse: collapse;
    }

    .att-table th {
        background: #f5f6fa;
        color: #526070;
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .07em;
        padding: .7rem 1rem;
        text-align: left;
    }

    .att-table td {
        border-top: 1px solid #edf0f6;
        padding: .75rem 1rem;
        vertical-align: middle;
        font-size: .8rem;
    }

    .att-student {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .att-photo {
        width: 2.1rem;
        height: 2.1rem;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #e5e7eb;
    }

    .att-name {
        color: var(--primary);
        font-weight: 900;
        line-height: 1.2;
    }

    .att-class {
        margin-top: .15rem;
        color: var(--muted);
        font-size: .7rem;
    }

    .att-pill {
        display: inline-flex;
        align-items: center;
        gap: .28rem;
        border-radius: 999px;
        padding: .24rem .55rem;
        font-size: .68rem;
        font-weight: 900;
        white-space: nowrap;
    }

    .att-pill.present { background: var(--green-soft); color: var(--green); }
    .att-pill.absent { background: var(--red-soft); color: var(--red); }
    .att-pill.late { background: var(--amber-soft); color: var(--amber); }
    .att-pill.excused { background: #eef0ff; color: var(--primary); }
    .att-pill.not-marked { background: #f1f3f7; color: #6b7280; }

    .att-marked {
        color: #334155;
        font-size: .76rem;
        line-height: 1.35;
    }

    .att-marked span {
        color: var(--primary);
        font-weight: 900;
    }

    .att-row-form {
        display: grid;
        grid-template-columns: 8rem minmax(11rem, 1fr) auto;
        gap: .45rem;
        align-items: center;
    }

    .att-row-form .att-select,
    .att-row-form .att-input {
        height: 2rem;
        font-size: .76rem;
    }

    .att-empty {
        text-align: center;
        color: #7a8294;
        padding: 2.2rem 1rem !important;
    }

    @@media (max-width: 1180px) {
        .att-filter { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .att-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .att-table { min-width: 950px; }
        .att-panel { overflow-x: auto; }
    }

    @@media (max-width: 700px) {
        .att-filter,
        .att-stats {
            grid-template-columns: 1fr;
        }
    }
</style>
}

<div class="att-page">
    <div class="att-head">
        <div>
            <h1 class="att-title">Attendance Management</h1>
            <p class="att-sub">Review class attendance, adjust student status, and see marks submitted from teacher dashboards.</p>
        </div>
        <a class="att-btn ghost" href="@Url.Action("Index", "Students")">
            <i class="bi bi-people"></i>
            Student Records
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="att-alert ok">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="att-alert err">@TempData["Error"]</div>
    }

    <form class="att-filter" method="get" action="@Url.Action("Index", "Attendance")">
        <div class="att-field">
            <label>Class</label>
            <select class="att-select" name="classId">
                @if (!Model.ClassOptions.Any())
                {
                    <option value="">No classes yet</option>
                }
                @foreach (var item in Model.ClassOptions)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
        </div>
        <div class="att-field">
            <label>Date</label>
            <input class="att-input" type="date" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="att-field">
            <label>Student Search</label>
            <input class="att-input" name="search" value="@Model.Search" placeholder="Search by student name..." />
        </div>
        <div class="att-field">
            <label>Status</label>
            <select class="att-select" name="status">
                <option value="">All statuses</option>
                <option value="Present" selected="@(Model.Status == "Present")">Present</option>
                <option value="Absent" selected="@(Model.Status == "Absent")">Absent</option>
                <option value="Late" selected="@(Model.Status == "Late")">Late</option>
                <option value="Excused" selected="@(Model.Status == "Excused")">Excused</option>
                <option value="Not Marked" selected="@(Model.Status == "Not Marked")">Not marked</option>
            </select>
        </div>
        <button class="att-btn primary" type="submit">
            <i class="bi bi-search"></i>
            Apply
        </button>
    </form>

    <div class="att-stats">
        <div class="att-stat">
            <div class="att-stat-icon"><i class="bi bi-people-fill"></i></div>
            <div><div class="att-stat-label">Selected Students</div><div class="att-stat-value">@Model.TotalStudents</div></div>
        </div>
        <div class="att-stat" style="border-top-color:#1b6d24">
            <div class="att-stat-icon" style="background:#e8f8ea;color:#1b6d24"><i class="bi bi-check-circle-fill"></i></div>
            <div><div class="att-stat-label">Present</div><div class="att-stat-value" style="color:#1b6d24">@Model.PresentCount</div></div>
        </div>
        <div class="att-stat" style="border-top-color:#ba1a1a">
            <div class="att-stat-icon" style="background:#ffefed;color:#ba1a1a"><i class="bi bi-x-circle-fill"></i></div>
            <div><div class="att-stat-label">Absent</div><div class="att-stat-value" style="color:#ba1a1a">@Model.AbsentCount</div></div>
        </div>
        <div class="att-stat" style="border-top-color:#b76400">
            <div class="att-stat-icon" style="background:#fff4df;color:#b76400"><i class="bi bi-clock-fill"></i></div>
            <div><div class="att-stat-label">Late</div><div class="att-stat-value" style="color:#b76400">@Model.LateCount</div></div>
        </div>
        <div class="att-stat" style="border-top-color:#8b8fa3">
            <div class="att-stat-icon" style="background:#f1f3f7;color:#6b7280"><i class="bi bi-dash-circle-fill"></i></div>
            <div><div class="att-stat-label">Not Marked</div><div class="att-stat-value" style="color:#6b7280">@Model.NotMarkedCount</div></div>
        </div>
    </div>

    <div class="att-panel">
        <div class="att-panel-head">
            <h2 class="att-panel-title">Daily Register - @Model.SelectedDate.ToString("dd MMM yyyy")</h2>
            <span style="font-size:.76rem;color:#697083;">Teacher-submitted rows keep the teacher name until admin edits them.</span>
        </div>

        <table class="att-table">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Status</th>
                    <th>Marked By</th>
                    <th>Admin Update</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Students.Any())
            {
                <tr>
                    <td colspan="4" class="att-empty">No students found for this class or filter.</td>
                </tr>
            }
            @foreach (var row in Model.Students)
            {
                var pillClass = row.Status.ToLowerInvariant().Replace(" ", "-");
                <tr>
                    <td>
                        <div class="att-student">
                            <img class="att-photo" src="@row.PhotoPath" onerror="this.src='/images/default-avatar.png'" alt="@row.StudentName" />
                            <div>
                                <div class="att-name">@row.StudentName</div>
                                <div class="att-class">@row.ClassName</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="att-pill @pillClass">
                            <i class="bi @(row.Status == "Present" ? "bi-check-circle-fill" : row.Status == "Absent" ? "bi-x-circle-fill" : row.Status == "Late" ? "bi-clock-fill" : "bi-dash-circle-fill")"></i>
                            @row.Status
                        </span>
                    </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(row.MarkedByName))
                        {
                            <div class="att-marked">
                                <span>@row.MarkedByName</span> marked this student as <strong>@row.Status</strong>
                                @if (row.MarkedAt.HasValue)
                                {
                                    <div style="color:#7a8294;">@row.MarkedAt.Value.ToString("dd MMM yyyy, HH:mm")</div>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="color:#9aa1b2;">Waiting for teacher or admin mark</span>
                        }
                    </td>
                    <td>
                        <form class="att-row-form" method="post" action="@Url.Action("SaveStatus", "Attendance")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="StudentId" value="@row.StudentId" />
                            <input type="hidden" name="ClassId" value="@row.ClassId" />
                            <input type="hidden" name="SelectedClassId" value="@Model.SelectedClassId" />
                            <input type="hidden" name="AttendanceDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <select class="att-select" name="Status">
                                @foreach (var option in statusOptions)
                                {
                                    <option value="@option" selected="@(row.Status == option)">@option</option>
                                }
                            </select>
                            <input class="att-input" name="Notes" value="@row.Notes" placeholder="Admin note..." />
                            <button class="att-btn primary" type="submit">
                                <i class="bi bi-save"></i>
                                Save
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
