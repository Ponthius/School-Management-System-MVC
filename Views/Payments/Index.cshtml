@model School_Management_System.Models.ViewModels.PaymentDashboardViewModel
@{
    ViewData["Title"] = "Fee Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="portal-page">
    <div class="portal-head">
        <div>
            <h1 class="portal-title">Fee Management</h1>
            <p class="portal-subtitle">Record payments, track balances, and print receipts.</p>
        </div>
        <div class="portal-actions">
            <a class="portal-btn ghost" href="@Url.Action("DownloadReport", "Payments")"><i class="bi bi-download"></i> Download Report</a>
            <button class="portal-btn primary" type="button" onclick="openPortalModal('paymentModal')"><i class="bi bi-plus-lg"></i> Quick Record Payment</button>
        </div>
    </div>

    @if (TempData["Success"] != null) { <div class="portal-alert ok">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="portal-alert err">@TempData["Error"]</div> }

    <div class="portal-grid-3" style="margin-bottom:1rem;">
        <div class="portal-card green">
            <div class="portal-stat-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="portal-label">Total Fees Collected</div>
            <div class="portal-value">@Model.TotalCollected.ToString("N0")</div>
        </div>
        <div class="portal-card amber">
            <div class="portal-stat-icon"><i class="bi bi-clipboard2-pulse"></i></div>
            <div class="portal-label">Total Pending</div>
            <div class="portal-value">@Model.TotalPending.ToString("N0")</div>
            <p class="portal-subtitle">@Model.OverdueCount overdue balances</p>
        </div>
        <div class="portal-card">
            <div class="portal-stat-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="portal-label">Collection Efficiency</div>
            <div class="portal-value">@Model.CollectionEfficiency.ToString("0.#")%</div>
        </div>
    </div>

    <div class="portal-panel">
        <div class="portal-panel-head">
            <h2 class="portal-panel-title">Recent Transactions</h2>
            <form method="get" class="portal-actions">
                <input class="portal-input" name="search" value="@Model.Search" placeholder="Search receipt or student..." />
                <button class="portal-btn ghost" type="submit"><i class="bi bi-search"></i> Search</button>
            </form>
        </div>
        <table class="portal-table">
            <thead><tr><th>Student</th><th>Date</th><th>Amount Paid</th><th>Balance</th><th>Status</th><th style="text-align:right;">Action</th></tr></thead>
            <tbody>
            @if (!Model.Payments.Any())
            {
                <tr><td colspan="6" class="portal-empty">No payments recorded yet.</td></tr>
            }
            @foreach (var payment in Model.Payments)
            {
                <tr>
                    <td>
                        <strong>@payment.Student?.FullName</strong>
                        <div class="portal-subtitle">@payment.ReceiptNumber</div>
                    </td>
                    <td>@payment.Date.ToString("dd MMM yyyy")</td>
                    <td>@payment.Amount.ToString("N0")</td>
                    <td>@payment.Balance.ToString("N0")</td>
                    <td><span class="portal-pill @(payment.Balance <= 0 ? "green" : "amber")">@payment.Status</span></td>
                    <td style="text-align:right;"><a class="portal-btn ghost" href="@Url.Action("Receipt", "Payments", new { id = payment.Id })">View Receipt</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div id="paymentModal" class="portal-modal-backdrop">
    <div class="portal-modal">
        <div class="portal-modal-head">
            <h3 class="portal-modal-title">Quick Record Payment</h3>
            <button class="portal-close" type="button" onclick="closePortalModal('paymentModal')">&times;</button>
        </div>
        <form class="portal-modal-body" method="post" action="@Url.Action("Record", "Payments")">
            @Html.AntiForgeryToken()
            <div class="portal-form-grid" style="grid-template-columns:1fr 1fr;">
                <div class="portal-field" style="grid-column:1 / -1;">
                    <label>Student</label>
                    <select class="portal-select" name="StudentId" required>
                        <option value="">Select student</option>
                        @foreach (var student in Model.Students)
                        {
                            <option value="@student.Value">@student.Text</option>
                        }
                    </select>
                </div>
                <div class="portal-field">
                    <label>Amount Paid</label>
                    <input class="portal-input" type="number" step="0.01" name="Amount" required />
                </div>
                <div class="portal-field">
                    <label>Fee Amount Due</label>
                    <input class="portal-input" type="number" step="0.01" name="FeeAmountDue" placeholder="Optional" />
                </div>
                <div class="portal-field">
                    <label>Term</label>
                    <input class="portal-input" name="Term" placeholder="Current Term" />
                </div>
                <div class="portal-field">
                    <label>Method</label>
                    <select class="portal-select" name="PaymentMethod">
                        <option>Cash</option>
                        <option>Bank Transfer</option>
                        <option>Mobile Money</option>
                        <option>Card</option>
                    </select>
                </div>
                <div class="portal-field" style="grid-column:1 / -1;">
                    <label>Notes</label>
                    <textarea class="portal-textarea" name="Notes" rows="3"></textarea>
                </div>
            </div>
            <div class="portal-actions" style="justify-content:flex-end;margin-top:1rem;">
                <button class="portal-btn ghost" type="button" onclick="closePortalModal('paymentModal')">Cancel</button>
                <button class="portal-btn primary" type="submit">Confirm Payment Entry</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openPortalModal(id){ document.getElementById(id).classList.add('show'); }
function closePortalModal(id){ document.getElementById(id).classList.remove('show'); }
</script>
}
