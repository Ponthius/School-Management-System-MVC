@model School_Management_System.Models.ViewModels.ExamPrintTimetableViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Exam Timetable - Brait Inc SMS</title>
    <style>
        body {
            margin: 0;
            background: #f4f5f8;
            font-family: Consolas, "Courier New", monospace;
            color: #111827;
        }

        .receipt {
            width: 380px;
            margin: 24px auto;
            background: white;
            border: 1px solid #d8dce7;
            padding: 18px;
            box-shadow: 0 10px 30px rgba(16, 24, 40, .12);
        }

        .center {
            text-align: center;
        }

        h1 {
            margin: 0;
            font-size: 18px;
            letter-spacing: .04em;
        }

        .muted {
            color: #667085;
            font-size: 12px;
        }

        .line {
            border-top: 1px dashed #9aa3b2;
            margin: 12px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        th,
        td {
            padding: 6px 0;
            border-bottom: 1px dotted #d0d5dd;
            vertical-align: top;
            text-align: left;
        }

        th:last-child,
        td:last-child {
            text-align: right;
        }

        .print-btn {
            display: block;
            width: 380px;
            margin: 0 auto 18px;
            border: 0;
            border-radius: 4px;
            background: #000666;
            color: white;
            padding: 10px 12px;
            font-weight: 700;
            cursor: pointer;
        }

        @@media print {
            body {
                background: white;
            }

            .print-btn {
                display: none;
            }

            .receipt {
                margin: 0;
                width: 100%;
                border: 0;
                box-shadow: none;
            }
        }
    </style>
</head>
<body>
    <button class="print-btn" onclick="window.print()">Print Timetable</button>
    <div class="receipt">
        <div class="center">
            <h1>BRAIT INC SMS</h1>
            <div class="muted">EXAM TIMETABLE</div>
            <div class="muted">@Model.TermName</div>
        </div>

        <div class="line"></div>

        <table>
            <thead>
                <tr>
                    <th>Class</th>
                    <th>Exam</th>
                    <th>Room</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Schedules.Any())
            {
                <tr>
                    <td colspan="3" class="center">No schedules found.</td>
                </tr>
            }
            @foreach (var item in Model.Schedules)
            {
                <tr>
                    <td>@item.ClassName</td>
                    <td>
                        @item.SubjectName<br />
                        <span class="muted">@item.ExamDate.ToString("dd MMM") @item.StartTime.ToString("hh\\:mm")-@item.EndTime.ToString("hh\\:mm")</span><br />
                        <span class="muted">@item.InvigilatorName</span>
                    </td>
                    <td>@item.RoomNumber</td>
                </tr>
            }
            </tbody>
        </table>

        <div class="line"></div>
        <div class="center muted">Printed @DateTime.Now.ToString("dd MMM yyyy HH:mm")</div>
    </div>
</body>
</html>
