@model School_Management_System.Models.Teacher
@{
    ViewData["Title"] = "Teacher Profile";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var subjects = Model.AssignedSubjects
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(s => s.Trim())
        .Where(s => s.Length > 0)
        .ToList();
}

<div style="max-width:680px;margin:0 auto">
    <div style="margin-bottom:1rem;display:flex;
                align-items:center;justify-content:space-between">
        <a href="/Teachers"
           style="font-size:.78rem;color:#1e2a78;text-decoration:none;
                  display:inline-flex;align-items:center;gap:.3rem">
            <i class="bi bi-arrow-left"></i> Back to Teachers
        </a>
        <a href="/Teachers/Edit/@Model.Id"
           style="border:1px solid #d97706;color:#d97706;border-radius:.25rem;
                  padding:.38rem .85rem;font-size:.78rem;font-weight:600;
                  text-decoration:none;display:inline-flex;align-items:center;gap:.3rem">
            <i class="bi bi-pencil"></i> Edit
        </a>
    </div>

    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:.4rem;overflow:hidden">
        <!-- Header band -->
        <div style="background:#1e2a78;padding:1.4rem 1.5rem;
                    display:flex;align-items:center;gap:1rem">
            <img src="@Model.PhotoPath"
                 onerror="this.src='/images/default-avatar.png'"
                 style="width:3.8rem;height:3.8rem;border-radius:50%;
                        object-fit:cover;border:2px solid rgba(255,255,255,.3)"/>
            <div>
                <div style="color:#fff;font-size:1.1rem;font-weight:700">
                    @Model.FullName
                </div>
                <div style="color:rgba(255,255,255,.65);font-size:.8rem">
                    @Model.Email
                </div>
                <span style="margin-top:.35rem;display:inline-block;font-size:.7rem;
                             font-weight:700;padding:.18rem .55rem;border-radius:999px;
                             background:@(Model.Status=="Active"
                                ? "rgba(34,197,94,.2)" : "rgba(239,68,68,.2)");
                             color:@(Model.Status=="Active" ? "#86efac" : "#fca5a5")">
                    @Model.Status
                </span>
            </div>
        </div>

        <!-- Details grid -->
        <div style="padding:1.2rem 1.5rem;
                    display:grid;grid-template-columns:1fr 1fr;gap:1.1rem">
            @{
                void Field(string label, string value) {
                    <div>
                        <div style="font-size:.68rem;text-transform:uppercase;
                                    letter-spacing:.07em;font-weight:700;
                                    color:#9ca3af;margin-bottom:.2rem">@label</div>
                        <div style="font-size:.88rem;font-weight:600;color:#111827">
                            @value
                        </div>
                    </div>;
                }
            }
            @{ Field("Full Name",     Model.FullName); }
            @{ Field("Email",         Model.Email.Length > 0 ? Model.Email : "—"); }
            @{ Field("Primary Class", Model.PrimaryClass?.Name ?? "—"); }
            @{ Field("Status",        Model.Status); }
            @{ Field("Joined",        Model.JoinedDate.ToString("dd MMM yyyy")); }
            @{ Field("Login Username", Model.User?.Username ?? "—"); }
        </div>

        <!-- Subjects -->
        @if (subjects.Any())
        {
            <div style="padding:.8rem 1.5rem 1.2rem;
                        border-top:1px solid #f3f4f6">
                <div style="font-size:.68rem;text-transform:uppercase;
                            letter-spacing:.07em;font-weight:700;
                            color:#9ca3af;margin-bottom:.5rem">
                    Assigned Subjects
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:.35rem">
                    @foreach (var sub in subjects)
                    {
                        <span style="font-size:.7rem;font-weight:700;
                                     text-transform:uppercase;letter-spacing:.05em;
                                     padding:.22rem .55rem;border-radius:.2rem;
                                     background:#e0e7ff;color:#3730a3">
                            @sub
                        </span>
                    }
                </div>
            </div>
        }
    </div>
</div>